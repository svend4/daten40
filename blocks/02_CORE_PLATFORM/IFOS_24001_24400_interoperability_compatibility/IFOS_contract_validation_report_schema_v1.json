{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Contract Validation Report Schema v1",
  "type": "object",
  "required": [
    "report_id",
    "contract_id",
    "status",
    "findings",
    "updated_at",
    "version"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "contract_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}