  "contract_send_telegram": {
    "contract_id": "ctr.t.d130t8nlih",
    "action": "send_telegram_message",
    "title": "Send Telegram Message",
    "description": "Отправляет сообщение в Telegram по chat_id.",
    "inputs": [
      {
        "name": "chat_id",
        "type": "pii_string",
        "required": true,
        "constraints": {
          "minLength": 1
        },
        "semantics": [
          "chat_id",
          "pii"
        ],
        "example": "-100123"
      },
      {
        "name": "text",
        "type": "string",
        "required": true,
        "constraints": {
          "maxLength": 4096
        },
        "semantics": [
          "message"
        ],
        "example": "Hello!"
      }
    ],
    "outputs": [
      {
        "name": "message_id",
        "type": "string",
        "constraints": {},
        "example": "42"
      }
    ],
    "errors": [
      {
        "code": "RATE_LIMIT",
        "handling": "backoff",
        "idempotent": false
      },
      {
        "code": "AUTH_FAIL",
        "handling": "fail_fast",
        "idempotent": true
      }
    ],
    "tags": [
      "communication",
      "telegram"
    ],
    "policy": {
      "no_log_fields": [
        "chat_id"
      ],
      "requires_secret": [
        "secret://telegram/bot_token"
      ]
