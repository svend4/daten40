{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Compatibility Score Schema v1",
  "type": "object",
  "required": [
    "score_id",
    "subject_id",
    "platform",
    "profile_id",
    "score",
    "reasons",
    "updated_at",
    "version"
  ],
  "properties": {
    "score_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "platform": {
      "type": "string",
      "enum": [
        "make",
        "n8n",
        "wordpress",
        "custom"
      ]
    },
    "profile_id": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "breakdown": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}