{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Dashboard Schema v1",
  "type": "object",
  "required": [
    "dashboard_id",
    "title",
    "sections",
    "version"
  ],
  "properties": {
    "dashboard_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "items"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "kind",
                "ref"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "vitrine",
                    "card",
                    "widget",
                    "link"
                  ]
                },
                "ref": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}