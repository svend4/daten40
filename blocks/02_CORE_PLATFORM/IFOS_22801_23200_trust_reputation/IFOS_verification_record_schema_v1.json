{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Verification Record Schema v1",
  "type": "object",
  "required": [
    "verification_id",
    "subject_id",
    "checks",
    "result",
    "ts",
    "updated_at",
    "version"
  ],
  "properties": {
    "verification_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "signature_valid",
              "sbom_present",
              "license_ok",
              "policy_ok",
              "hash_match"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "ts": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}