{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Moderation Appeal Schema v1",
  "type": "object",
  "required": [
    "appeal_id",
    "subject_id",
    "reason",
    "evidence",
    "status",
    "ts",
    "updated_at",
    "version"
  ],
  "properties": {
    "appeal_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "in_review",
        "accepted",
        "rejected"
      ]
    },
    "ts": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}