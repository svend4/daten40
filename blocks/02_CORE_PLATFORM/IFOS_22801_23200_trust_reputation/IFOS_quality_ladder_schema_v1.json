{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Quality Ladder Schema v1",
  "type": "object",
  "required": [
    "ladder_id",
    "levels",
    "updated_at",
    "version"
  ],
  "properties": {
    "ladder_id": {
      "type": "string"
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "level",
          "name",
          "requirements"
        ],
        "properties": {
          "level": {
            "type": "string",
            "enum": [
              "L0",
              "L1",
              "L2",
              "L3",
              "L4",
              "L5"
            ]
          },
          "name": {
            "type": "string"
          },
          "requirements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}