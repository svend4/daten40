{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Anti-Fraud Detection Schema v1",
  "type": "object",
  "required": [
    "finding_id",
    "subject_id",
    "signals",
    "score",
    "label",
    "ts",
    "updated_at",
    "version"
  ],
  "properties": {
    "finding_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "label": {
      "type": "string",
      "enum": [
        "clean",
        "suspicious",
        "fraud_likely"
      ]
    },
    "ts": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}