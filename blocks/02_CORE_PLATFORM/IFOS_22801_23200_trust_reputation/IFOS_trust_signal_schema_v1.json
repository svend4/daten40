{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Trust Signal Schema v1",
  "type": "object",
  "required": [
    "signal_id",
    "subject_id",
    "type",
    "value",
    "source",
    "ts",
    "confidence",
    "updated_at",
    "version"
  ],
  "properties": {
    "signal_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "coverage_docs",
        "coverage_tests",
        "stability_fail_ratio",
        "stability_mttr",
        "security_signed",
        "security_sbom",
        "adoption_installs",
        "support_response_time",
        "compat_score",
        "cost_efficiency",
        "incident_count",
        "rollback_rate"
      ]
    },
    "value": {
      "type": [
        "number",
        "string",
        "boolean",
        "object"
      ]
    },
    "source": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "observability",
            "publisher",
            "review",
            "audit",
            "system"
          ]
        },
        "ref": {
          "type": "string"
        }
      }
    },
    "ts": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}