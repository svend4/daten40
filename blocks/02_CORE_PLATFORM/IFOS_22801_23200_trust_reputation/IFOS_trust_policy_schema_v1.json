{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Trust Policy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "name",
    "min_level_for_sandbox",
    "min_level_for_prod",
    "requirements",
    "updated_at",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "min_level_for_sandbox": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4",
        "L5"
      ]
    },
    "min_level_for_prod": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4",
        "L5"
      ]
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}