{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS IngestJob Schema v1",
  "type": "object",
  "required": [
    "ingest_id",
    "source_id",
    "status",
    "stats",
    "created_at",
    "updated_at",
    "version"
  ],
  "properties": {
    "ingest_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed"
      ]
    },
    "window": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "stats": {
      "type": "object",
      "properties": {
        "items_created": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "receipt_ref": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}