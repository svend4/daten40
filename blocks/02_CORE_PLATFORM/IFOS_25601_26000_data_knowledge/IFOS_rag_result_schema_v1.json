{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RAGResult Schema v1",
  "type": "object",
  "required": [
    "result_id",
    "query_id",
    "answer",
    "citations",
    "confidence",
    "updated_at",
    "version"
  ],
  "properties": {
    "result_id": {
      "type": "string"
    },
    "query_id": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "record_id"
        ],
        "properties": {
          "record_id": {
            "type": "string"
          },
          "span": {
            "type": "string"
          },
          "score": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}