{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PII Classification Schema v1",
  "type": "object",
  "required": [
    "class_id",
    "level",
    "fields",
    "updated_at",
    "version"
  ],
  "properties": {
    "class_id": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high"
      ]
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}