{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS KnowledgeGraph Schema v1",
  "type": "object",
  "required": [
    "graph_id",
    "entities",
    "links",
    "updated_at",
    "version"
  ],
  "properties": {
    "graph_id": {
      "type": "string"
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}