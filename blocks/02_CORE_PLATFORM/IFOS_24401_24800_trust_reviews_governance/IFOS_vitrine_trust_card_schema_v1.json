{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vitrine Trust Card Schema v1",
  "type": "object",
  "required": [
    "subject_id",
    "trust_score",
    "badges",
    "top_reviews",
    "risks",
    "policy_status",
    "updated_at",
    "version"
  ],
  "properties": {
    "subject_id": {
      "type": "string"
    },
    "trust_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "badges": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "top_reviews": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy_status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}