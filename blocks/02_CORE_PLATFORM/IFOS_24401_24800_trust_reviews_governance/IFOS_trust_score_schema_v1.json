{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Trust Score Schema v1",
  "type": "object",
  "required": [
    "score_id",
    "entity_id",
    "entity_type",
    "score",
    "breakdown",
    "reasons",
    "computed_at",
    "updated_at",
    "version"
  ],
  "properties": {
    "score_id": {
      "type": "string"
    },
    "entity_id": {
      "type": "string"
    },
    "entity_type": {
      "type": "string",
      "enum": [
        "publisher",
        "subject"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "breakdown": {
      "type": "object",
      "additionalProperties": true
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "computed_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}