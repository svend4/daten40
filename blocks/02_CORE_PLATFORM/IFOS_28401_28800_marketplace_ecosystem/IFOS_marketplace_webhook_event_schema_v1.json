{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS MarketplaceWebhookEvent Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "kind",
    "ts",
    "payload",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "package.published",
        "package.installed",
        "review.created",
        "package.updated",
        "publisher.verified"
      ]
    },
    "ts": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}