{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RatingAggregate Schema v1",
  "type": "object",
  "required": [
    "package_id",
    "avg",
    "count",
    "distribution",
    "confidence",
    "updated_at",
    "version"
  ],
  "properties": {
    "package_id": {
      "type": "string"
    },
    "avg": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "distribution": {
      "type": "object",
      "properties": {
        "1": {
          "type": "integer",
          "minimum": 0
        },
        "2": {
          "type": "integer",
          "minimum": 0
        },
        "3": {
          "type": "integer",
          "minimum": 0
        },
        "4": {
          "type": "integer",
          "minimum": 0
        },
        "5": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "confidence": {
      "type": "object",
      "properties": {
        "low": {
          "type": "number"
        },
        "high": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}