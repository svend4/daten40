{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Alert Rule Schema v1",
  "type": "object",
  "required": [
    "rule_id",
    "name",
    "severity",
    "condition",
    "window_s",
    "routing",
    "suppression",
    "runbook_ref",
    "updated_at",
    "version"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "P1",
        "P2",
        "P3"
      ]
    },
    "condition": {
      "type": "object",
      "required": [
        "metric",
        "op",
        "threshold"
      ],
      "properties": {
        "metric": {
          "type": "string"
        },
        "op": {
          "type": "string",
          "enum": [
            ">",
            "<",
            ">=",
            "<=",
            "==",
            "!="
          ]
        },
        "threshold": {
          "type": "number"
        }
      }
    },
    "window_s": {
      "type": "integer",
      "minimum": 10,
      "maximum": 86400
    },
    "routing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suppression": {
      "type": "object",
      "properties": {
        "cooldown_s": {
          "type": "integer"
        },
        "max_per_hour": {
          "type": "integer"
        }
      }
    },
    "runbook_ref": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}