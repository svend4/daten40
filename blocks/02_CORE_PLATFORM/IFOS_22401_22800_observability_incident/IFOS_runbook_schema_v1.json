{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Runbook Schema v1",
  "type": "object",
  "required": [
    "runbook_id",
    "name",
    "triggers",
    "steps",
    "updated_at",
    "version"
  ],
  "properties": {
    "runbook_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}