{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Degradation Action Schema v1",
  "type": "object",
  "required": [
    "action_id",
    "type",
    "params",
    "updated_at",
    "version"
  ],
  "properties": {
    "action_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "switch_variant",
        "enable_offline_queue",
        "enable_dry_run",
        "reduce_frequency",
        "disable_step"
      ]
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}