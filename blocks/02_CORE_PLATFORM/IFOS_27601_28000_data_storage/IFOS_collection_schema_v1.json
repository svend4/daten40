{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Collection Schema v1",
  "type": "object",
  "required": [
    "collection_id",
    "workspace_id",
    "name",
    "schema_profile",
    "retention_policy_ref",
    "created_at",
    "updated_at",
    "version"
  ],
  "properties": {
    "collection_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "schema_profile": {
      "type": "object",
      "properties": {
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "language": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "filters": {
      "type": "object",
      "additionalProperties": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retention_policy_ref": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}