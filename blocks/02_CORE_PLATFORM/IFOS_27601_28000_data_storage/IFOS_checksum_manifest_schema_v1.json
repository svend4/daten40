{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ChecksumManifest Schema v1",
  "type": "object",
  "required": [
    "manifest_id",
    "kind",
    "entries",
    "created_at",
    "version"
  ],
  "properties": {
    "manifest_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "bundle",
        "evidence_pack",
        "backup_snapshot"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}