{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Artifact Schema v1",
  "type": "object",
  "required": [
    "artifact_id",
    "workspace_id",
    "type",
    "uri",
    "checksum",
    "created_by_run_id",
    "created_at",
    "retention_policy_ref",
    "version"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "collection_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "markdown",
        "csv",
        "json",
        "html",
        "log",
        "evidence_pack",
        "binary",
        "other"
      ]
    },
    "uri": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "checksum": {
      "type": "string"
    },
    "created_by_run_id": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retention_policy_ref": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}