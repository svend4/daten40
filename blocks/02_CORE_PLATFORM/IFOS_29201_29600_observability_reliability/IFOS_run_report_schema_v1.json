{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RunReport Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "target",
    "started_at",
    "ended_at",
    "status",
    "metrics",
    "logs_ref",
    "trace_id",
    "artifacts",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "job",
            "flow",
            "package",
            "vitrine"
          ]
        },
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "started_at": {
      "type": "string"
    },
    "ended_at": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error",
        "cancelled"
      ]
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "logs_ref": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}