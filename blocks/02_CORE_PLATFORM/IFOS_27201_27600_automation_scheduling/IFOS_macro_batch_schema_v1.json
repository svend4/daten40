{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS MacroBatch Schema v1",
  "type": "object",
  "required": [
    "macro_batch_id",
    "name",
    "steps",
    "version"
  ],
  "properties": {
    "macro_batch_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "macro",
              "flow",
              "package"
            ]
          },
          "ref": {
            "type": "string"
          },
          "params": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}