{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS JobRun Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "job_id",
    "status",
    "queued_at",
    "started_at",
    "finished_at",
    "attempt",
    "artifacts",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "dead_letter"
      ]
    },
    "queue_id": {
      "type": "string"
    },
    "worker_id": {
      "type": "string"
    },
    "queued_at": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "error_code": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}