{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS FlowGraph Schema v1",
  "type": "object",
  "required": [
    "flow_id",
    "workspace_id",
    "nodes",
    "edges",
    "triggers",
    "updated_at",
    "version"
  ],
  "properties": {
    "flow_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "condition": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "manual",
              "schedule",
              "webhook"
            ]
          },
          "spec": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  },
  "$defs": {
    "node": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "IFOS FlowNode Schema v1",
      "type": "object",
      "required": [
        "node_id",
        "type",
        "params",
        "version"
      ],
      "properties": {
        "node_id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "ingest",
            "normalize",
            "dedupe",
            "embed",
            "rag_query",
            "export",
            "notify",
            "transform",
            "custom"
          ]
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "on_error": {
          "type": "string",
          "enum": [
            "stop",
            "retry",
            "skip",
            "fallback"
          ]
        },
        "version": {
          "type": "string"
        }
      }
    }
  }
}