{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DemoSession Schema v1",
  "type": "object",
  "required": [
    "demo_id",
    "template_id",
    "workspace_id",
    "status",
    "steps",
    "started_at",
    "version"
  ],
  "properties": {
    "demo_id": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "running",
        "completed",
        "failed"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "done"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "done": {
            "type": "boolean"
          },
          "hint": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}