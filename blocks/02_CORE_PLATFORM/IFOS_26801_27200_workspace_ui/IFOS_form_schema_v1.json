{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS FormSchema v1",
  "type": "object",
  "required": [
    "form_id",
    "fields",
    "version"
  ],
  "properties": {
    "form_id": {
      "type": "string"
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "label",
          "type"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "string",
              "number",
              "boolean",
              "select",
              "secret_ref",
              "url",
              "json"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "default": {
            "type": [
              "string",
              "number",
              "boolean",
              "object",
              "array",
              "null"
            ]
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "help": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}