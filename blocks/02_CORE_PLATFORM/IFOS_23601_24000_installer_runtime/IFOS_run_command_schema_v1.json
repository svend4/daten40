{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Run Command Schema v1",
  "type": "object",
  "required": [
    "cmd_id",
    "subject_id",
    "mode",
    "params",
    "updated_at",
    "version"
  ],
  "properties": {
    "cmd_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "run_once",
        "schedule",
        "webhook",
        "daemon"
      ]
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}