{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Policy Gate Result Schema v1",
  "type": "object",
  "required": [
    "gate_id",
    "subject_id",
    "policy_id",
    "status",
    "findings",
    "updated_at",
    "version"
  ],
  "properties": {
    "gate_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "policy_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}