{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Reference Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "name",
    "kind",
    "scope",
    "updated_at",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "api_key",
        "token",
        "oauth",
        "password",
        "webhook_secret"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "dev",
        "sandbox",
        "staging",
        "prod"
      ]
    },
    "rotation_days": {
      "type": "integer"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}