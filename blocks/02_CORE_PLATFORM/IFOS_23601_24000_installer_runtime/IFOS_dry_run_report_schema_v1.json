{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Dry Run Report Schema v1",
  "type": "object",
  "required": [
    "report_id",
    "request_id",
    "will_install",
    "permissions",
    "secrets_needed",
    "risks",
    "policy_gates",
    "updated_at",
    "version"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "will_install": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "secrets_needed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}