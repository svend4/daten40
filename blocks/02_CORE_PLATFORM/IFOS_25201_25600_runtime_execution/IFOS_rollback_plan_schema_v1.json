{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Rollback Plan Schema v1",
  "type": "object",
  "required": [
    "rollback_id",
    "subject_id",
    "strategy",
    "steps",
    "updated_at",
    "version"
  ],
  "properties": {
    "rollback_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "strategy": {
      "type": "string",
      "enum": [
        "best_effort",
        "strict"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "n",
          "action"
        ],
        "properties": {
          "n": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string"
          },
          "adapter_ref": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}