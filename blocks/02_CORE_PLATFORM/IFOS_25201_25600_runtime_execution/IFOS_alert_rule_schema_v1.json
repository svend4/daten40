{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Alert Rule Schema v1",
  "type": "object",
  "required": [
    "alert_id",
    "name",
    "condition",
    "severity",
    "updated_at",
    "version"
  ],
  "properties": {
    "alert_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "condition": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "critical"
      ]
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}