{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Execution Report Schema v1",
  "type": "object",
  "required": [
    "report_id",
    "job_id",
    "summary",
    "links",
    "updated_at",
    "version"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "links": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}