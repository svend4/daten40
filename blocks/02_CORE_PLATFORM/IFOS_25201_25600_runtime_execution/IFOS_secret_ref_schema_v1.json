{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretRef Schema v1",
  "type": "object",
  "required": [
    "secret_ref",
    "kind",
    "scope",
    "rotation_policy",
    "updated_at",
    "version"
  ],
  "properties": {
    "secret_ref": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "api_key",
        "token",
        "oauth_refresh_token",
        "password",
        "certificate"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "workspace",
        "profile",
        "publisher",
        "user"
      ]
    },
    "rotation_policy": {
      "type": "object",
      "properties": {
        "rotate_days": {
          "type": "integer",
          "minimum": 0
        },
        "notify_before_days": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "redaction_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}