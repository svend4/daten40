{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretRef Schema v1",
  "type": "object",
  "required": [
    "secret_ref",
    "type",
    "scope",
    "store_ref",
    "version"
  ],
  "properties": {
    "secret_ref": {
      "type": "string",
      "description": "Reference name only; no secret value."
    },
    "type": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth_token",
        "basic_auth",
        "jwt",
        "certificate",
        "other"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "workspace",
        "project",
        "user",
        "global"
      ]
    },
    "store_ref": {
      "type": "string"
    },
    "rotation": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval_days": {
          "type": "integer",
          "minimum": 0
        },
        "last_rotated_at": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}