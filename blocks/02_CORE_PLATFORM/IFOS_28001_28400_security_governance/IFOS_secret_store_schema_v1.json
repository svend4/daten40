{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretStore Schema v1",
  "type": "object",
  "required": [
    "store_id",
    "kind",
    "config",
    "encryption",
    "enabled",
    "version"
  ],
  "properties": {
    "store_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "local_encrypted",
        "vault",
        "cloud_kms",
        "env",
        "other"
      ]
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "encryption": {
      "type": "object",
      "properties": {
        "at_rest": {
          "type": "boolean"
        },
        "method": {
          "type": "string"
        },
        "key_ref": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "enabled": {
      "type": "boolean"
    },
    "version": {
      "type": "string"
    }
  }
}