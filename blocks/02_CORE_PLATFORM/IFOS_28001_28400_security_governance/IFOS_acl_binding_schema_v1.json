{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ACLBinding Schema v1",
  "type": "object",
  "required": [
    "binding_id",
    "workspace_id",
    "subject",
    "resource",
    "actions",
    "effect",
    "version"
  ],
  "properties": {
    "binding_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "service"
          ]
        },
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "resource": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "workspace",
            "collection",
            "job",
            "package",
            "artifact",
            "secret_ref",
            "source",
            "index",
            "other"
          ]
        },
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "effect": {
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "reason": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}