{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Test Result Schema v1",
  "type": "object",
  "required": [
    "result_id",
    "suite_id",
    "status",
    "cases",
    "run_at",
    "updated_at",
    "version"
  ],
  "properties": {
    "result_id": {
      "type": "string"
    },
    "suite_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "status"
        ],
        "properties": {
          "case_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skip"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "run_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}