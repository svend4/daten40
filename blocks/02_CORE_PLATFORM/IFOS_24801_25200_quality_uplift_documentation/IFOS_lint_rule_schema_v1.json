{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Lint Rule Schema v1",
  "type": "object",
  "required": [
    "rule_id",
    "name",
    "description",
    "severity",
    "updated_at",
    "version"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "fail"
      ]
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}