{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Changelog Schema v1",
  "type": "object",
  "required": [
    "changelog_id",
    "subject_id",
    "entries",
    "updated_at",
    "version"
  ],
  "properties": {
    "changelog_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "version",
          "date",
          "changes"
        ],
        "properties": {
          "version": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}