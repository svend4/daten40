{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Test Case Schema v1",
  "type": "object",
  "required": [
    "case_id",
    "contract_id",
    "inputs",
    "assertions",
    "updated_at",
    "version"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "contract_id": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}