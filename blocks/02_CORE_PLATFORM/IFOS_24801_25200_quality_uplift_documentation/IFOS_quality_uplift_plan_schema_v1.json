{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Quality Uplift Plan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "subject_id",
    "from_level",
    "to_level",
    "tasks",
    "updated_at",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "from_level": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4",
        "L5"
      ]
    },
    "to_level": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4",
        "L5"
      ]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "add_contract",
              "add_adapter",
              "add_tests",
              "add_docs",
              "add_ci",
              "add_rollback",
              "sign_artifacts",
              "collect_receipts"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "todo",
              "doing",
              "done",
              "blocked"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}