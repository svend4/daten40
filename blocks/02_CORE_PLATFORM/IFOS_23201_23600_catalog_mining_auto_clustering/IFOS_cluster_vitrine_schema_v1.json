{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Cluster Vitrine Schema v1",
  "type": "object",
  "required": [
    "vitrine_id",
    "cluster_id",
    "headline",
    "cards",
    "cta",
    "updated_at",
    "version"
  ],
  "properties": {
    "vitrine_id": {
      "type": "string"
    },
    "cluster_id": {
      "type": "string"
    },
    "headline": {
      "type": "string"
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "bullets"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "bullets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk": {
            "type": "string"
          }
        }
      }
    },
    "cta": {
      "type": "object",
      "properties": {
        "install": {
          "type": "string"
        },
        "sandbox": {
          "type": "string"
        },
        "docs": {
          "type": "string"
        }
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}