{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Atom Function Schema v1",
  "type": "object",
  "required": [
    "atom_id",
    "action",
    "title",
    "inputs",
    "outputs",
    "deps",
    "constraints",
    "cost_model",
    "sources",
    "updated_at",
    "version"
  ],
  "properties": {
    "atom_id": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "example": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "example": {
            "type": "string"
          }
        }
      }
    },
    "deps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "cost_model": {
      "type": "object",
      "additionalProperties": true
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}