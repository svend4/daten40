{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Labeling Decision Schema v1",
  "type": "object",
  "required": [
    "decision_id",
    "subject_id",
    "labels",
    "reason",
    "ts",
    "updated_at",
    "version"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}