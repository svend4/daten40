{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Feedback Loop Schema v1",
  "type": "object",
  "required": [
    "loop_id",
    "inputs",
    "actions",
    "updated_at",
    "version"
  ],
  "properties": {
    "loop_id": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}