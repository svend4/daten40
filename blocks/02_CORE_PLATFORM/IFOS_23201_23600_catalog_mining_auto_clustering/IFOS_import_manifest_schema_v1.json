{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Import Manifest Schema v1",
  "type": "object",
  "required": [
    "manifest_id",
    "sources",
    "policy",
    "updated_at",
    "version"
  ],
  "properties": {
    "manifest_id": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}