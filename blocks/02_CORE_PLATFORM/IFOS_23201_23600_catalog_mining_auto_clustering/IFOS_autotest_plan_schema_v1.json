{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Autotest Plan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "subject_id",
    "tests",
    "updated_at",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "expected"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "smoke",
              "integration",
              "contract"
            ]
          },
          "inputs": {
            "type": "object",
            "additionalProperties": true
          },
          "expected": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}