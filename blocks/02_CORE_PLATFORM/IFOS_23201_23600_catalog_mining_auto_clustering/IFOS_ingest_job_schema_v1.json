{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Ingest Job Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "source_id",
    "status",
    "stages",
    "created_at",
    "updated_at",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "failed",
        "completed"
      ]
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "fetch",
              "normalize",
              "extract",
              "dedupe",
              "embed",
              "cluster",
              "publish"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "failed",
              "completed"
            ]
          },
          "metrics": {
            "type": "object",
            "additionalProperties": true
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}