{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Extractor Rule Schema v1",
  "type": "object",
  "required": [
    "rule_id",
    "source_type",
    "patterns",
    "outputs",
    "updated_at",
    "version"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}