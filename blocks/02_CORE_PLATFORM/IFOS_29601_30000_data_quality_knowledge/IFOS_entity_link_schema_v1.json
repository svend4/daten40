{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS EntityLink Schema v1",
  "type": "object",
  "required": [
    "link_id",
    "a",
    "b",
    "relation",
    "evidence",
    "confidence",
    "version"
  ],
  "properties": {
    "link_id": {
      "type": "string"
    },
    "a": {
      "type": "string"
    },
    "b": {
      "type": "string"
    },
    "relation": {
      "type": "string",
      "enum": [
        "alias_of",
        "owned_by",
        "depends_on",
        "integrates_with",
        "competes_with",
        "successor_of",
        "other"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "version": {
      "type": "string"
    }
  }
}