{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Entity Schema v1",
  "type": "object",
  "required": [
    "entity_id",
    "type",
    "name",
    "aliases",
    "refs",
    "version"
  ],
  "properties": {
    "entity_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "company",
        "product",
        "service",
        "library",
        "person",
        "plugin",
        "connector",
        "other"
      ]
    },
    "name": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}