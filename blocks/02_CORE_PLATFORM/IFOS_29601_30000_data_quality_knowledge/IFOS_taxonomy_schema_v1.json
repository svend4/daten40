{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Taxonomy Schema v1",
  "type": "object",
  "required": [
    "taxonomy_id",
    "categories",
    "tags",
    "synonyms",
    "version"
  ],
  "properties": {
    "taxonomy_id": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "parent": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "synonyms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "a",
          "b"
        ],
        "properties": {
          "a": {
            "type": "string"
          },
          "b": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "alias",
              "rename",
              "translation"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}