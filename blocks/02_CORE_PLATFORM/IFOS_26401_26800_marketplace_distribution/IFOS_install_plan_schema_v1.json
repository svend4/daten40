{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS InstallPlan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "target_runtime",
    "steps",
    "rollback",
    "updated_at",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "target_runtime": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "fetch",
              "verify",
              "configure",
              "migrate",
              "install",
              "start",
              "healthcheck"
            ]
          },
          "ref": {
            "type": "string"
          },
          "params": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "secrets_needed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}