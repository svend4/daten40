{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Policy Gate Decision Schema v1",
  "type": "object",
  "required": [
    "decision_id",
    "plan_id",
    "run_id",
    "decision",
    "reasons",
    "remediation",
    "risks",
    "updated_at",
    "version"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "needs_review"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remediation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}