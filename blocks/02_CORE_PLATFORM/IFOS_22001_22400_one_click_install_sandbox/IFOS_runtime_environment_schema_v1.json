{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Runtime Environment Schema v1",
  "type": "object",
  "required": [
    "env_id",
    "kind",
    "platform",
    "resources",
    "network",
    "updated_at",
    "version"
  ],
  "properties": {
    "env_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "docker",
        "vm",
        "k8s",
        "platform_staging"
      ]
    },
    "platform": {
      "type": "string"
    },
    "resources": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        },
        "disk": {
          "type": "string"
        }
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "egress_allowed": {
          "type": "boolean"
        },
        "allow_domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}