{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Smoke Test Result Schema v1",
  "type": "object",
  "required": [
    "test_id",
    "run_id",
    "name",
    "status",
    "checks",
    "duration_ms",
    "updated_at",
    "version"
  ],
  "properties": {
    "test_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "check": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "warn"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 1
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}