{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Sandbox Run Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "plan_id",
    "environment",
    "network_policy",
    "status",
    "artifacts",
    "started_at",
    "updated_at",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "environment": {
      "type": "object",
      "additionalProperties": true
    },
    "network_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "running",
        "success",
        "fail"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "logs_ref": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}