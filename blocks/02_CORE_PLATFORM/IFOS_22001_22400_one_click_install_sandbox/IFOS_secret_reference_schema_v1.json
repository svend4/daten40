{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Reference Schema v1",
  "type": "object",
  "required": [
    "ref",
    "kind",
    "location",
    "updated_at",
    "version"
  ],
  "properties": {
    "ref": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "vault",
        "env",
        "k8s",
        "file",
        "make_credential",
        "n8n_credential",
        "wordpress_option"
      ]
    },
    "location": {
      "type": "string"
    },
    "redaction": {
      "type": "boolean",
      "default": true
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}