{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Credential Binding Schema v1",
  "type": "object",
  "required": [
    "binding_id",
    "capability",
    "platform",
    "secret_ref",
    "scope",
    "status",
    "updated_at",
    "version"
  ],
  "properties": {
    "binding_id": {
      "type": "string"
    },
    "capability": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "secret_ref": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "properties": {
        "env": {
          "type": "string"
        },
        "workspace": {
          "type": "string"
        },
        "asset_id": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "bound",
        "disabled"
      ]
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}