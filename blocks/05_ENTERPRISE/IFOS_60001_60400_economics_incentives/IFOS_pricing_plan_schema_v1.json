{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Pricing Plan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "model",
    "currency",
    "price",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "model": {
      "type": "string",
      "enum": [
        "free",
        "one_time",
        "subscription",
        "usage",
        "tiered",
        "bundle"
      ]
    },
    "currency": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "usage_unit": {
      "type": "string"
    },
    "tiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}