{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Warranty Schema v1",
  "type": "object",
  "required": [
    "warranty_id",
    "coverage",
    "limits",
    "version"
  ],
  "properties": {
    "warranty_id": {
      "type": "string"
    },
    "coverage": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": true
    },
    "claims_process": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}