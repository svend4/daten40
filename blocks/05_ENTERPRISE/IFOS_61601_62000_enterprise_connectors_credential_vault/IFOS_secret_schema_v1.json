{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "name",
    "kind",
    "scope",
    "created_at",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth_token",
        "password",
        "certificate",
        "token_map"
      ]
    },
    "scope": {
      "type": "object",
      "required": [
        "workspace_id",
        "project_id",
        "env"
      ],
      "properties": {
        "workspace_id": {
          "type": "string"
        },
        "project_id": {
          "type": "string"
        },
        "env": {
          "type": "string",
          "enum": [
            "dev",
            "stage",
            "prod",
            "sandbox"
          ]
        }
      }
    },
    "connector_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "expires_at": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "encrypted": {
          "type": "boolean"
        },
        "kms_key_id": {
          "type": "string"
        }
      }
    },
    "version": {
      "type": "string"
    }
  }
}