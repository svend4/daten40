{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Connector Credential Requirement Schema v1",
  "type": "object",
  "required": [
    "connector_id",
    "auth_type",
    "fields",
    "supports_env",
    "version"
  ],
  "properties": {
    "connector_id": {
      "type": "string"
    },
    "auth_type": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth2",
        "basic",
        "mtls",
        "custom"
      ]
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "secret": {
            "type": "boolean"
          },
          "help": {
            "type": "string"
          }
        }
      }
    },
    "supports_env": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "health_check": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}