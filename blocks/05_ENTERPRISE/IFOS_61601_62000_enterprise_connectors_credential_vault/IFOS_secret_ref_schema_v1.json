{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Ref Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "ref_type",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "ref_type": {
      "type": "string",
      "enum": [
        "direct",
        "by_connector",
        "by_tag"
      ]
    },
    "selector": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}