{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Env Profile Schema v1",
  "type": "object",
  "required": [
    "profile_id",
    "env",
    "policies",
    "version"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "env": {
      "type": "string",
      "enum": [
        "dev",
        "stage",
        "prod",
        "sandbox"
      ]
    },
    "region": {
      "type": "string"
    },
    "policies": {
      "type": "object",
      "additionalProperties": true
    },
    "network": {
      "type": "object",
      "additionalProperties": true
    },
    "logging": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}