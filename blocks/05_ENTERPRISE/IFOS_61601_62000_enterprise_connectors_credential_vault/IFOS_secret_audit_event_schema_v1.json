{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Audit Event Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "secret_id",
    "actor",
    "action",
    "timestamp",
    "decision",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "secret_id": {
      "type": "string"
    },
    "actor": {
      "type": "object",
      "additionalProperties": true
    },
    "action": {
      "type": "string",
      "enum": [
        "create",
        "use",
        "rotate",
        "revoke",
        "deny"
      ]
    },
    "timestamp": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "allowed",
        "denied"
      ]
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}