{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Alert",
  "type": "object",
  "required": [
    "alert_id",
    "severity",
    "subject",
    "recipients",
    "status",
    "created_at"
  ],
  "properties": {
    "alert_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "INFO",
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "subject": {
      "type": "string"
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "recipients": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "OPEN",
        "ACKED",
        "CLOSED"
      ]
    },
    "ack": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "acked_by": {
          "type": "string"
        },
        "acked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "related": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}