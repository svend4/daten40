{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS GatewayTLSPolicy Schema v1",
  "type": "object",
  "required": [
    "tls_policy_id",
    "min_tls",
    "verify_cert",
    "require_sni",
    "cipher_policy",
    "version"
  ],
  "properties": {
    "tls_policy_id": {
      "type": "string"
    },
    "min_tls": {
      "type": "string",
      "enum": [
        "1.2",
        "1.3"
      ]
    },
    "verify_cert": {
      "type": "boolean"
    },
    "require_sni": {
      "type": "boolean"
    },
    "cipher_policy": {
      "type": "string",
      "enum": [
        "modern",
        "intermediate",
        "strict"
      ]
    },
    "ca_allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "enable_pinning": {
      "type": "boolean",
      "default": false
    },
    "version": {
      "type": "string"
    }
  }
}