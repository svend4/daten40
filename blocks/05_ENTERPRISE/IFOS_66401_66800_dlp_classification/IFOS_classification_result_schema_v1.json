{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ClassificationResult Schema v1",
  "type": "object",
  "required": [
    "result_id",
    "created_at",
    "detected_classes",
    "labels",
    "confidence",
    "evidence",
    "version"
  ],
  "properties": {
    "result_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "detected_classes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule",
          "score"
        ],
        "properties": {
          "rule": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "redaction_suggestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}