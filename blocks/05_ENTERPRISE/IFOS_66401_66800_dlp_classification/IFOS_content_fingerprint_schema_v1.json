{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ContentFingerprint Schema v1",
  "type": "object",
  "required": [
    "fp_id",
    "algo",
    "hash",
    "created_at",
    "scope",
    "version"
  ],
  "properties": {
    "fp_id": {
      "type": "string"
    },
    "algo": {
      "type": "string",
      "enum": [
        "sha256",
        "simhash",
        "minhash"
      ]
    },
    "hash": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}