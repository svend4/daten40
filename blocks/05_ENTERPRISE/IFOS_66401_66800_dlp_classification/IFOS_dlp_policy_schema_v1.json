{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DlpPolicy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "mode",
    "rules",
    "sampling",
    "default_action",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "monitor_only",
        "enforce"
      ]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sampling": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "default_action": {
      "type": "string",
      "enum": [
        "ALLOW",
        "DENY"
      ]
    },
    "default_redaction_profile_id": {
      "type": "string"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}