{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Hostability Capability Schema v1",
  "type": "object",
  "required": [
    "capability_id",
    "name",
    "category",
    "version"
  ],
  "properties": {
    "capability_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "network",
        "runtime",
        "data",
        "security",
        "ops"
      ]
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}