{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Lab Schema v1",
  "type": "object",
  "required": [
    "lab_id",
    "title",
    "steps",
    "expected",
    "version"
  ],
  "properties": {
    "lab_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}