{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CDN Plan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "rules",
    "purge",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "purge": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}