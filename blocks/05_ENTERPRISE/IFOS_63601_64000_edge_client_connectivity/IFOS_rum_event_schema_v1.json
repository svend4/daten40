    "ts",
    "type",
    "value",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "value": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}