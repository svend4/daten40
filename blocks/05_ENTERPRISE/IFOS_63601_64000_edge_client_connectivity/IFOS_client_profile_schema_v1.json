{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Client Profile Schema v1",
  "type": "object",
  "required": [
    "client_id",
    "class",
    "platforms",
    "network",
    "version"
  ],
  "properties": {
    "client_id": {
      "type": "string"
    },
    "class": {
      "type": "string",
      "enum": [
        "low_end",
        "mid",
        "high",
        "enterprise"
      ]
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}