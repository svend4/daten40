{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Sync Plan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "entities",
    "conflict_strategy",
    "batching",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflict_strategy": {
      "type": "string",
      "enum": [
        "lww",
        "field_merge",
        "crdt",
        "manual"
      ]
    },
    "batching": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}