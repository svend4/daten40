{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Scope Policy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "scopes",
    "role_mapping",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "role_mapping": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}