{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS OIDC Provider Schema v1",
  "type": "object",
  "required": [
    "provider_id",
    "type",
    "issuer",
    "jwks_uri",
    "auth_endpoint",
    "token_endpoint",
    "userinfo_endpoint",
    "version"
  ],
  "properties": {
    "provider_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "internal",
        "external",
        "enterprise"
      ]
    },
    "issuer": {
      "type": "string"
    },
    "jwks_uri": {
      "type": "string"
    },
    "auth_endpoint": {
      "type": "string"
    },
    "token_endpoint": {
      "type": "string"
    },
    "userinfo_endpoint": {
      "type": "string"
    },
    "end_session_endpoint": {
      "type": "string"
    },
    "scopes_supported": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}