{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS OAuth Client App Schema v1",
  "type": "object",
  "required": [
    "client_id",
    "client_type",
    "grant_types",
    "pkce_required",
    "redirect_uris",
    "scopes",
    "version"
  ],
  "properties": {
    "client_id": {
      "type": "string"
    },
    "client_type": {
      "type": "string",
      "enum": [
        "web",
        "mobile",
        "desktop",
        "cli",
        "service"
      ]
    },
    "grant_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pkce_required": {
      "type": "boolean"
    },
    "redirect_uris": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "token_endpoint_auth_method": {
      "type": "string",
      "enum": [
        "none",
        "client_secret_post",
        "client_secret_basic",
        "private_key_jwt"
      ]
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}