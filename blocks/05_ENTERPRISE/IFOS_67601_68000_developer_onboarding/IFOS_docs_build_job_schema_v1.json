{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DocsBuildJob Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "created_at",
    "repo_ref",
    "docs_template_id",
    "formats",
    "status",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "repo_ref": {
      "type": "string"
    },
    "docs_template_id": {
      "type": "string"
    },
    "formats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "QUEUED",
        "RUNNING",
        "DONE",
        "FAILED"
      ]
    },
    "output_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}