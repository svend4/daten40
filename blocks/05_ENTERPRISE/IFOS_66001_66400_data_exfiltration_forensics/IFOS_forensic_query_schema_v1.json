{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ForensicQuery Schema v1",
  "type": "object",
  "required": [
    "query_id",
    "time_range",
    "filters",
    "fields",
    "limit",
    "version"
  ],
  "properties": {
    "query_id": {
      "type": "string"
    },
    "time_range": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": true
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "order_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100000
    },
    "version": {
      "type": "string"
    }
  }
}