{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Import Job Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "source_id",
    "status",
    "created_at",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed"
      ]
    },
    "options": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}