{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Import Result Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "assets",
    "scorecards",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scorecards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}