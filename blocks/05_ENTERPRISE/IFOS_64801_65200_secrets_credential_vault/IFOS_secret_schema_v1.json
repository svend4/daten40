{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "type",
    "tenant_id",
    "environment",
    "created_at",
    "storage",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth_client_secret",
        "refresh_token",
        "service_account_json",
        "webhook_secret",
        "password",
        "private_key",
        "certificate",
        "test_key"
      ]
    },
    "tenant_id": {
      "type": "string"
    },
    "environment": {
      "type": "string",
      "enum": [
        "dev",
        "test",
        "stage",
        "prod"
      ]
    },
    "owner": {
      "type": "object",
      "additionalProperties": true
    },
    "purpose": {
      "type": "string"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "expires_at": {
      "type": "string"
    },
    "rotation_policy_id": {
      "type": "string"
    },
    "storage": {
      "type": "object",
      "additionalProperties": true
    },
    "exportable": {
      "type": "boolean",
      "default": false
    },
    "never_expose_value": {
      "type": "boolean",
      "default": false
    },
    "version": {
      "type": "string"
    }
  }
}