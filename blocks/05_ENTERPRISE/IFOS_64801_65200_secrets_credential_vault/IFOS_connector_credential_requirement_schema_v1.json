{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Connector Credential Requirement Schema v1",
  "type": "object",
  "required": [
    "connector_id",
    "credential_type",
    "required_scopes",
    "usage",
    "validation",
    "version"
  ],
  "properties": {
    "connector_id": {
      "type": "string"
    },
    "credential_type": {
      "type": "string"
    },
    "required_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "usage": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": true
    },
    "safe_handling": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}