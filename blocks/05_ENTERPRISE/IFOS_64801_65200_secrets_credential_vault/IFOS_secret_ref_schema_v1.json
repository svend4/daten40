{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretRef Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "access_mode",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "access_mode": {
      "type": "string",
      "enum": [
        "lease",
        "read_once",
        "proxy_sign",
        "token_exchange"
      ]
    },
    "lease_ttl_s": {
      "type": "integer"
    },
    "mask_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}