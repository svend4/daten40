{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Access Grant Schema v1",
  "type": "object",
  "required": [
    "grant_id",
    "secret_id",
    "subject",
    "issued_at",
    "expires_at",
    "mode",
    "version"
  ],
  "properties": {
    "grant_id": {
      "type": "string"
    },
    "secret_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "additionalProperties": true
    },
    "issued_at": {
      "type": "string"
    },
    "expires_at": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "lease",
        "read_once",
        "proxy_sign",
        "token_exchange"
      ]
    },
    "usage_limit": {
      "type": "integer"
    },
    "version": {
      "type": "string"
    }
  }
}