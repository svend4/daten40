{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Test Key Schema v1",
  "type": "object",
  "required": [
    "test_key_id",
    "provider",
    "mode",
    "environment",
    "how_to_get",
    "version"
  ],
  "properties": {
    "test_key_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "sandbox",
        "test",
        "demo"
      ]
    },
    "environment": {
      "type": "string",
      "enum": [
        "dev",
        "test"
      ]
    },
    "rate_limits": {
      "type": "object",
      "additionalProperties": true
    },
    "how_to_get": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}