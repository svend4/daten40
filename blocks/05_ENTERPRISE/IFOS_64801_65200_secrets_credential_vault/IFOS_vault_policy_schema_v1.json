{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS VaultPolicy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "subjects",
    "resources",
    "actions",
    "conditions",
    "decision",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "subjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "allow_with_lease",
        "allow_with_mfa"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}