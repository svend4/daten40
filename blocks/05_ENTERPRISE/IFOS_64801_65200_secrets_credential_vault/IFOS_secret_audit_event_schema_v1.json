{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Audit Event Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "ts",
    "type",
    "actor",
    "secret_id",
    "decision",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "secret.create",
        "secret.read",
        "secret.lease",
        "secret.rotate",
        "secret.revoke",
        "policy.deny",
        "policy.allow"
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": true
    },
    "secret_id": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}