{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CredentialPolicy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "sandbox_only",
    "min_scopes",
    "deny_scopes",
    "endpoint_allowlist",
    "storage",
    "rotation",
    "logging",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "sandbox_only": {
      "type": "boolean"
    },
    "min_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deny_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "endpoint_allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "storage": {
      "type": "object",
      "required": [
        "vault_namespace",
        "encryption"
      ],
      "properties": {
        "vault_namespace": {
          "type": "string"
        },
        "encryption": {
          "type": "string",
          "enum": [
            "kms",
            "vault_native",
            "hsm"
          ]
        }
      },
      "additionalProperties": false
    },
    "rotation": {
      "type": "object",
      "required": [
        "enabled",
        "every_days"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "every_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        }
      },
      "additionalProperties": false
    },
    "logging": {
      "type": "object",
      "required": [
        "redact_secrets",
        "forbid_plaintext_export"
      ],
      "properties": {
        "redact_secrets": {
          "type": "boolean"
        },
        "forbid_plaintext_export": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "version": {
      "type": "string"
    }
  }
}