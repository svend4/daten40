{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Dataset Schema v1",
  "type": "object",
  "required": [
    "dataset_id",
    "name",
    "fixtures",
    "version"
  ],
  "properties": {
    "dataset_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "fixtures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fixture"
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "seed": {
      "type": "integer"
    },
    "locale": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "$defs": {
      "fixture": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "IFOS Fixture Schema v1",
        "type": "object",
        "required": [
          "fixture_id",
          "type",
          "payload",
          "version"
        ],
        "properties": {
          "fixture_id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          },
          "refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "version": {
            "type": "string"
          }
        }
      }
    }
  }
}