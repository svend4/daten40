{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Contract Test Schema v1",
  "type": "object",
  "required": [
    "test_id",
    "connector_id",
    "mode",
    "assertions",
    "version"
  ],
  "properties": {
    "test_id": {
      "type": "string"
    },
    "connector_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "official_sandbox",
        "mock",
        "replay"
      ]
    },
    "setup": {
      "type": "object",
      "additionalProperties": true
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}