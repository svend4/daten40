{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ResourceLimits Schema v1",
  "type": "object",
  "required": [
    "resource_limits_id",
    "cpu_cores",
    "memory_mb",
    "disk_mb",
    "wall_time_s",
    "max_concurrency",
    "version"
  ],
  "properties": {
    "resource_limits_id": {
      "type": "string"
    },
    "cpu_cores": {
      "type": "number"
    },
    "memory_mb": {
      "type": "integer"
    },
    "disk_mb": {
      "type": "integer"
    },
    "wall_time_s": {
      "type": "integer"
    },
    "max_concurrency": {
      "type": "integer"
    },
    "version": {
      "type": "string"
    }
  }
}