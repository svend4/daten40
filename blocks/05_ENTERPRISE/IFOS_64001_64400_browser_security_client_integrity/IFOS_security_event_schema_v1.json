{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Security Event Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "ts",
    "type",
    "severity",
    "context",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "ts": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}