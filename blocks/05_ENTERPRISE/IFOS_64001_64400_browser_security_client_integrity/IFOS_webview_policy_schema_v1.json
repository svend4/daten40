{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS WebView Policy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "supported",
    "known_issues",
    "workarounds",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "supported": {
      "type": "boolean"
    },
    "known_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workarounds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}