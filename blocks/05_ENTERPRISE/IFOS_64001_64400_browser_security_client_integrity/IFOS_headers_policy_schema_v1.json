{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Headers Policy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "headers",
    "applies_to",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}