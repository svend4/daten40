{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SolutionPlan",
  "type": "object",
  "required": [
    "capability_graph",
    "bundle_manifest",
    "gaps"
  ],
  "properties": {
    "capability_graph": {
      "type": "object",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "capability_id"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "capability_id": {
                "type": "string"
              },
              "confidence": {
                "type": "number"
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "from",
              "to",
              "type"
            ],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "requires",
                  "part_of",
                  "sequence"
                ]
              }
            }
          }
        }
      }
    },
    "selected_components": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "bundle_manifest": {
      "type": "object"
    },
    "blueprint_pack": {
      "type": "object"
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "message"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "explanations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}