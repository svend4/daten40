{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Hybrid Gateway Schema v1",
  "type": "object",
  "required": [
    "gateway_id",
    "env",
    "policies",
    "version"
  ],
  "properties": {
    "gateway_id": {
      "type": "string"
    },
    "env": {
      "type": "string"
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mtls": {
      "type": "boolean"
    },
    "auditing": {
      "type": "boolean"
    },
    "version": {
      "type": "string"
    }
  }
}