{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Config Sync Job Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "from_env",
    "to_env",
    "steps",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "from_env": {
      "type": "string"
    },
    "to_env": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}