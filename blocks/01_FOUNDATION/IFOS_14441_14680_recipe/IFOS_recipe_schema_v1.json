{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Recipe Schema v1",
  "type": "object",
  "required": [
    "recipe_id",
    "title",
    "goal",
    "steps",
    "targets",
    "evidence_plan"
  ],
  "properties": {
    "recipe_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "type",
          "required"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "string",
              "number",
              "boolean",
              "enum",
              "secret_ref",
              "url",
              "json"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "default": {},
          "enum": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "kind",
          "required"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "api_key",
              "oauth",
              "password",
              "webhook_secret"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "pii": {
          "type": "boolean",
          "default": false
        },
        "money": {
          "type": "boolean",
          "default": false
        },
        "security_sensitive": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "action",
              "transform",
              "filter",
              "foreach",
              "rate_limit",
              "store"
            ]
          },
          "uses": {
            "type": "string",
            "description": "function_id when kind=action"
          },
          "expr": {
            "type": "string",
            "description": "expression when kind=transform/filter"
          },
          "in": {
            "type": "object"
          },
          "out": {
            "type": "object"
          },
          "on_error": {
            "type": "object",
            "properties": {
              "strategy": {
                "type": "string",
                "enum": [
                  "retry",
                  "skip",
                  "fail"
                ],
                "default": "fail"
              },
              "max_retries": {
                "type": "integer",
                "default": 0
              },
              "backoff_ms": {
                "type": "integer",
                "default": 0
              }
            }
          },
          "idempotent": {
            "type": "boolean",
            "default": false
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "make_blueprint_json",
          "n8n_workflow_json",
          "wp_bundle_manifest_json",
          "cli_script_bash",
          "cli_script_python"
        ]
      }
    },
    "evidence_plan": {
      "type": "object"
    }
  }
}