{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SDK Manifest Schema v1",
  "type": "object",
  "required": [
    "sdk_id",
    "name",
    "capabilities",
    "connectors",
    "schemas",
    "errors",
    "version",
    "updated_at"
  ],
  "properties": {
    "sdk_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "connectors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "interface": {
            "type": "string"
          },
          "auth_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "schema_ref": {
            "type": "string"
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "meaning": {
            "type": "string"
          },
          "retryable": {
            "type": "boolean"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}