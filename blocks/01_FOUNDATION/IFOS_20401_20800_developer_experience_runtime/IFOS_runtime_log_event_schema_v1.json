{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Runtime Log Event Schema v1",
  "type": "object",
  "required": [
    "log_id",
    "at",
    "level",
    "correlation_id",
    "job_id",
    "step_id",
    "message",
    "fields",
    "version",
    "updated_at"
  ],
  "properties": {
    "log_id": {
      "type": "string"
    },
    "at": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "correlation_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "step_id": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "fields": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}