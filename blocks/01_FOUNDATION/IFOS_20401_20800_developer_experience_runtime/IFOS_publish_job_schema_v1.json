{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Publish Job Schema v1",
  "type": "object",
  "required": [
    "publish_id",
    "subject",
    "steps",
    "status",
    "artifacts",
    "created_at",
    "version",
    "updated_at"
  ],
  "properties": {
    "publish_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "running",
              "skip"
            ]
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "success",
        "fail"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}