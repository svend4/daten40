{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Version Migration Schema v1",
  "type": "object",
  "required": [
    "migration_id",
    "from_version",
    "to_version",
    "changes",
    "script_ref",
    "version",
    "updated_at"
  ],
  "properties": {
    "migration_id": {
      "type": "string"
    },
    "from_version": {
      "type": "string"
    },
    "to_version": {
      "type": "string"
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "rename",
              "delete",
              "default",
              "transform"
            ]
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "script_ref": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}