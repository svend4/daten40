{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vitrine/Portfolio Schema v1",
  "type": "object",
  "required": [
    "vitrine_id",
    "name",
    "intent",
    "selection",
    "curation_rules",
    "updated_at",
    "version"
  ],
  "properties": {
    "vitrine_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "selection": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string"
          },
          "position": {
            "type": "integer"
          },
          "tag": {
            "type": "string"
          }
        }
      }
    },
    "curation_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}