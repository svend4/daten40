{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS A/B Experiment Schema v1",
  "type": "object",
  "required": [
    "experiment_id",
    "hypothesis",
    "variants",
    "metrics",
    "guardrails",
    "status",
    "created_at",
    "version",
    "updated_at"
  ],
  "properties": {
    "experiment_id": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "traffic_split": {
            "type": "number"
          }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "running",
        "stopped",
        "completed"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}