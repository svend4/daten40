{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS License Schema v1",
  "type": "object",
  "required": [
    "license_id",
    "name",
    "rules",
    "attribution",
    "version",
    "updated_at"
  ],
  "properties": {
    "license_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "rules": {
      "type": "object",
      "properties": {
        "commercial_use": {
          "type": "boolean"
        },
        "redistribution": {
          "type": "boolean"
        },
        "modifications": {
          "type": "boolean"
        },
        "attribution_required": {
          "type": "boolean"
        },
        "data_restrictions": {
          "type": "string"
        }
      }
    },
    "attribution": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}