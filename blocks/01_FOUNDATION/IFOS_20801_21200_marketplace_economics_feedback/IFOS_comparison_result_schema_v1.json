{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Comparison Result Schema v1",
  "type": "object",
  "required": [
    "comparison_id",
    "intent",
    "candidates",
    "criteria",
    "table",
    "winner",
    "version",
    "updated_at"
  ],
  "properties": {
    "comparison_id": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "table": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "subject_id": {
            "type": "string"
          },
          "scores": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "winner": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}