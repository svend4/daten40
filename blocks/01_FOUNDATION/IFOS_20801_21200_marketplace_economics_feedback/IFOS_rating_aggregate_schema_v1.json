{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Rating Aggregate Schema v1",
  "type": "object",
  "required": [
    "subject_id",
    "count",
    "mean",
    "median",
    "distribution",
    "confidence",
    "verified_usage_ratio",
    "updated_at",
    "version"
  ],
  "properties": {
    "subject_id": {
      "type": "string"
    },
    "count": {
      "type": "integer"
    },
    "mean": {
      "type": "number"
    },
    "median": {
      "type": "number"
    },
    "distribution": {
      "type": "object",
      "properties": {
        "1": {
          "type": "integer"
        },
        "2": {
          "type": "integer"
        },
        "3": {
          "type": "integer"
        },
        "4": {
          "type": "integer"
        },
        "5": {
          "type": "integer"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "verified_usage_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "decay_model": {
      "type": "string",
      "default": "exponential_90d"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}