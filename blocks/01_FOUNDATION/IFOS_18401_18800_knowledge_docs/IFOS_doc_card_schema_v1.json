{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Doc Card Schema v1",
  "type": "object",
  "required": [
    "doc_card_id",
    "subject",
    "one_liner",
    "inputs",
    "outputs",
    "quick_fixes",
    "links",
    "version",
    "updated_at"
  ],
  "properties": {
    "doc_card_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "one_liner": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "example": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "example": {
            "type": "string"
          }
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quick_fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "symptom": {
            "type": "string"
          },
          "fix": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          }
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "page",
              "tutorial",
              "faq",
              "troubleshooting",
              "registry",
              "policy",
              "evidence"
            ]
          },
          "ref": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}