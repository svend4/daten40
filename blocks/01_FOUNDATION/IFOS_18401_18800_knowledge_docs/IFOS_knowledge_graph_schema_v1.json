{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Knowledge Graph Schema v1",
  "type": "object",
  "required": [
    "graph_id",
    "nodes",
    "edges",
    "version",
    "updated_at"
  ],
  "properties": {
    "graph_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "asset",
              "term",
              "faq",
              "tutorial",
              "case",
              "evidence",
              "page"
            ]
          },
          "label": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "type"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "mentions",
              "requires",
              "explains",
              "fixes",
              "derived_from",
              "validated_by",
              "links_to"
            ]
          },
          "weight": {
            "type": "number"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}