{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Tutorial Schema v1",
  "type": "object",
  "required": [
    "tutorial_id",
    "title",
    "goal",
    "steps",
    "expected_result",
    "refs",
    "version",
    "updated_at"
  ],
  "properties": {
    "tutorial_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "do"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "do": {
            "type": "string"
          },
          "check": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "expected_result": {
      "type": "string"
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}