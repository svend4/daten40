{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Troubleshooting Case Schema v1",
  "type": "object",
  "required": [
    "case_id",
    "title",
    "symptoms",
    "likely_causes",
    "checks",
    "fix_steps",
    "prevention",
    "affected_versions",
    "refs",
    "version",
    "updated_at"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "symptoms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "likely_causes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cause": {
            "type": "string"
          },
          "probability": {
            "type": "number"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "check": {
            "type": "string"
          },
          "how": {
            "type": "string"
          },
          "expected": {
            "type": "string"
          }
        }
      }
    },
    "fix_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prevention": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_versions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}