  "doc_card": {
    "doc_card_id": "dcard.news.ly3xi5mzy7",
    "subject": {
      "kind": "bundle",
      "id": "bundle.news_digest.core",
      "version": "1.0.0"
    },
    "one_liner": "Собирает новости из RSS, фильтрует и отправляет сводку в Telegram по расписанию.",
    "inputs": [
      {
        "name": "telegram_bot_token",
        "type": "secret",
        "required": true,
        "example": "123:ABC..."
      },
      {
        "name": "chat_id",
        "type": "text",
        "required": true,
        "example": "-1001234567890"
      },
      {
        "name": "rss_urls",
        "type": "list[url]",
        "required": true,
        "example": "https://example.com/rss"
      }
    ],
    "outputs": [
      {
        "name": "telegram_message",
        "type": "text",
        "example": "Top-5: ..."
      },
      {
        "name": "run_log",
        "type": "json",
        "example": "{status:'pass', items: 5}"
      }
    ],
    "requirements": [
      "Telegram Bot",
      "Network access to RSS sources"
    ],
    "quick_fixes": [
      {
        "symptom": "TOKEN_INVALID / 401",
        "fix": "Проверьте токен BotFather и повторите test connection.",
        "ref": "case.telegram.401"
      },
      {
        "symptom": "RSS timeout",
        "fix": "Проверьте URL и включите retry/backoff.",
        "ref": "case.rss.timeout"
      }
    ],
