  "faq_item": {
    "faq_id": "faq.telegram.token_invalid",
    "question": "Почему Telegram пишет TOKEN_INVALID?",
    "answer": "Обычно токен скопирован с пробелом или бот удалён/перегенерирован. Пересоздайте токен в BotFather и выполните test connection.",
    "actions": [
      {
        "label": "Открыть шаг wizard: токены",
        "type": "open_wizard_step",
        "ref": "wiz.news_digest:st.req"
      },
      {
        "label": "Проверить соединение",
        "type": "test_connection",
        "ref": "/adapters/telegram/test"
      },
      {
        "label": "Открыть troubleshooting case",
        "type": "open_troubleshooting_case",
        "ref": "case.telegram.401"
      }
    ],
    "refs": [
      "case.telegram.401",
      "term.webhook"
    ],
    "version": "1.0.0",
    "updated_at": "2026-01-02T18:00:00Z"
  },
  "troubleshooting_case": {
    "case_id": "case.telegram.401",
    "title": "Telegram 401 TOKEN_INVALID",
    "symptoms": [
      "Test connection returns 401",
      "Messages not delivered"
    ],
    "likely_causes": [
      {
        "cause": "Токен неверный/устарел",
        "probability": 0.75,
        "notes": "Часто пробел/не тот бот."
      },
      {
        "cause": "Бот заблокирован/удалён",
        "probability": 0.15,
        "notes": "Проверьте BotFather."
      },
      {
        "cause": "Прокси/фильтр ломает запрос",
        "probability": 0.1,
        "notes": "Проверьте сеть и TLS."
      }
    ],
    "checks": [
      {
        "check": "Сделать test connection",
        "how": "Нажать кнопку 'Проверить' в форме",
        "expected": "HTTP 200 OK + bot username"
      },
      {
        "check": "Сверить токен",
        "how": "Скопировать заново из BotFather",
        "expected": "Токен без пробелов"
      }
    ],
    "fix_steps": [
      "Пересоздайте токен BotFather",
      "Вставьте токен в secret field",
      "Повторите test connection",
      "Сделайте dry-run"
    ],
    "prevention": [
      "Не хранить токен в заметках без контроля",
      "Включить redaction в логах"
    ],
    "affected_versions": [
      "all"
    ],
    "refs": [
      "faq.telegram.token_invalid",
      "page.news_digest.core"
    ],
    "version": "1.0.0",
    "updated_at": "2026-01-02T18:00:00Z"
  },
  "tutorial": {
    "tutorial_id": "tut.news_digest.first_run",
    "title": "Первый запуск News Digest за 5 минут",
    "goal": "Получить первое сообщение в Telegram из 2 RSS источников.",
    "steps": [
      {
        "id": "1",
        "title": "Создайте бота",
        "do": "BotFather → /newbot → получите token",
        "check": "У вас есть token",
        "notes": "Не публикуйте token."
      },
      {
        "id": "2",
        "title": "Укажите chat_id",
        "do": "Добавьте бота в чат и узнайте chat_id",
        "check": "chat_id заполнен",
        "notes": "Для каналов нужен admin."
      },
      {
        "id": "3",
        "title": "Добавьте RSS",
        "do": "Вставьте 2 RSS URL",
        "check": "Test fetch returns items",
        "notes": "Если таймаут — см. case.rss.timeout."
      },
      {
        "id": "4",
        "title": "Dry-run",
        "do": "Запустите smoke test",
        "check": "status PASS",
        "notes": "В sandbox побочных эффектов нет."
      },
      {
        "id": "5",
        "title": "Запуск",
        "do": "Нажмите Run Now",
        "check": "Сообщение пришло в Telegram",
        "notes": "Если 401 — см. case.telegram.401."
      }
    ],
    "expected_result": "В Telegram пришла сводка с 2–5 пунктами.",
    "refs": [
      "page.news_digest.core",
      "case.telegram.401"
    ],
    "version": "1.0.0",
    "updated_at": "2026-01-02T18:00:00Z"
  },
