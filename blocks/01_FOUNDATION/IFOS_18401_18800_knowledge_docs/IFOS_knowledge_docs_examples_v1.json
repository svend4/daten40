  "workflow_explain": {
    "explain_id": "exp.wf.hx32ajwdry",
    "workflow_ref": "n8n.workflow.news_digest.123",
    "platform": "n8n",
    "summary": "Триггер по расписанию → fetch RSS → нормализация → дедуп → отправка в Telegram.",
    "blocks": [
      {
        "id": "b1",
        "type": "trigger",
        "name": "Cron daily 09:00",
        "inputs": [],
        "outputs": [
          "tick"
        ],
        "notes": ""
      },
      {
        "id": "b2",
        "type": "action",
        "name": "HTTP Request (RSS)",
        "inputs": [
          "tick",
          "rss_urls"
        ],
        "outputs": [
          "raw_feed"
        ],
        "notes": "network access"
      },
      {
        "id": "b3",
        "type": "transform",
        "name": "Parse RSS",
        "inputs": [
          "raw_feed"
        ],
        "outputs": [
          "items"
        ],
        "notes": ""
      },
      {
        "id": "b4",
        "type": "transform",
        "name": "Deduplicate",
        "inputs": [
          "items"
        ],
        "outputs": [
          "items_unique"
        ],
        "notes": "optional"
      },
      {
        "id": "b5",
        "type": "action",
        "name": "Telegram SendMessage",
        "inputs": [
          "items_unique",
          "telegram_bot_token",
          "chat_id"
        ],
        "outputs": [
          "sent"
        ],
        "notes": "secret token used"
      }
    ],
    "dataflow": [
      {
        "from": "b1",
        "to": "b2",
        "data": "tick",
        "redacted": false
      },
      {
        "from": "b2",
        "to": "b3",
        "data": "raw_feed",
        "redacted": false
      },
      {
        "from": "b3",
        "to": "b4",
        "data": "items",
        "redacted": false
      },
      {
        "from": "b4",
        "to": "b5",
        "data": "items_unique",
        "redacted": false
      },
      {
        "from": "form",
        "to": "b5",
        "data": "telegram_bot_token",
        "redacted": true
      }
    ],
    "risks": [
      {
        "level": "medium",
        "risk": "Network access to RSS sources",
        "mitigation": "Allowlist domains; retries+timeouts."
      },
      {
        "level": "high",
        "risk": "Secret token leakage in logs",
        "mitigation": "Enable redaction; disable debug."
      }
    ],
    "improvements": [
      "Добавить retry/backoff на HTTP fetch",
      "Добавить лимит источников и таймаут",
      "Сохранять hash последних заголовков для дедупа"
    ],
