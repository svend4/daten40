{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Doc Page Schema v1",
  "type": "object",
  "required": [
    "page_id",
    "subject",
    "title",
    "sections",
    "render",
    "version",
    "updated_at"
  ],
  "properties": {
    "page_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "title": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "body"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "render": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "md",
            "html"
          ]
        },
        "content_ref": {
          "type": "string"
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}