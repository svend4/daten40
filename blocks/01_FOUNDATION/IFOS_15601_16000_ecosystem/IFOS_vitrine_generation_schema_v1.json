{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vitrine Generation Schema v1",
  "type": "object",
  "required": [
    "vitrine_id",
    "name",
    "domain",
    "coverage_model",
    "selection_rules",
    "outputs",
    "method_version",
    "generated_at"
  ],
  "properties": {
    "vitrine_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "coverage_model": {
      "type": "object",
      "required": [
        "stages"
      ],
      "properties": {
        "stages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ingest",
              "transform",
              "store",
              "notify",
              "monitor",
              "admin"
            ]
          }
        }
      }
    },
    "selection_rules": {
      "type": "object",
      "properties": {
        "min_trust_score": {
          "type": "number"
        },
        "min_component_rating": {
          "type": "number"
        },
        "require_signed": {
          "type": "boolean"
        },
        "deny_flags": {
          "type": "object",
          "properties": {
            "pii": {
              "type": "boolean"
            },
            "money": {
              "type": "boolean"
            },
            "security_sensitive": {
              "type": "boolean"
            }
          }
        },
        "prefer_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "make",
              "n8n",
              "wp",
              "native",
              "cli"
            ]
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": [
        "bundles",
        "recipes",
        "adapters"
      ],
      "properties": {
        "bundles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recipes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "adapters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "generated_at": {
      "type": "string"
    },
    "method_version": {
      "type": "string"
    }
  }
}