{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Federation Node Schema v1",
  "type": "object",
  "required": [
    "node_id",
    "name",
    "base_url",
    "trust_policy",
    "created_at"
  ],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "base_url": {
      "type": "string"
    },
    "public_key": {
      "type": "string"
    },
    "trust_policy": {
      "type": "object",
      "required": [
        "accept_signed_only"
      ],
      "properties": {
        "accept_signed_only": {
          "type": "boolean"
        },
        "min_trust_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "allowed_publishers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_publishers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sync": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "pull",
            "push",
            "bidirectional"
          ]
        },
        "interval_min": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}