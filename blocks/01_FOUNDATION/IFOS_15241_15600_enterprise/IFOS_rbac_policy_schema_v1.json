{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RBAC/ABAC Policy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "tenant_id",
    "version",
    "rules",
    "created_at"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "effect",
          "actions",
          "roles"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "effect": {
            "type": "string",
            "enum": [
              "ALLOW",
              "DENY",
              "ALLOW_WITH_CONDITIONS"
            ]
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "resource_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "conditions": {
            "type": "object",
            "description": "ABAC conditions, e.g. flags, mode, level, time window"
          }
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}