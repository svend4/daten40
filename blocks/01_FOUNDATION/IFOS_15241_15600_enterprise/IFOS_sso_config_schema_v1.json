{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SSO Config Schema v1",
  "type": "object",
  "required": [
    "sso_config_id",
    "tenant_id",
    "provider",
    "enabled",
    "created_at"
  ],
  "properties": {
    "sso_config_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "provider": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "oidc",
            "saml"
          ]
        },
        "issuer": {
          "type": "string"
        },
        "client_id": {
          "type": "string"
        },
        "redirect_uris": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "saml_metadata_url": {
          "type": "string"
        }
      }
    },
    "scim": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "endpoint": {
          "type": "string"
        },
        "group_to_role_map": {
          "type": "object"
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}