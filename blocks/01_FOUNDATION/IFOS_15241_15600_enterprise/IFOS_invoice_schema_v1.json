{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Invoice Schema v1",
  "type": "object",
  "required": [
    "invoice_id",
    "tenant_id",
    "period",
    "currency",
    "lines",
    "total",
    "created_at"
  ],
  "properties": {
    "invoice_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "period": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "currency": {
      "type": "string"
    },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "meter",
          "qty",
          "unit_price",
          "amount"
        ],
        "properties": {
          "meter": {
            "type": "string"
          },
          "qty": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "amount": {
            "type": "number"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "tax": {
      "type": "number"
    },
    "total": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "issued",
        "paid",
        "void"
      ]
    },
    "created_at": {
      "type": "string"
    }
  }
}