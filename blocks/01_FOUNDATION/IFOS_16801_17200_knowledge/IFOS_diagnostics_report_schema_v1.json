{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Diagnostics Report Schema v1",
  "type": "object",
  "required": [
    "report_id",
    "run_id",
    "status",
    "signals",
    "hypotheses",
    "quick_fixes",
    "deep_fixes",
    "links",
    "generated_at",
    "method_version"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "warn",
        "fail"
      ]
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "cause",
          "prob"
        ],
        "properties": {
          "cause": {
            "type": "string"
          },
          "prob": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "quick_fixes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deep_fixes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at": {
      "type": "string"
    },
    "method_version": {
      "type": "string"
    }
  }
}