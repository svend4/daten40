        {
          "name": "chat_id",
          "type": "string",
          "required": true,
          "description": "ID чата/канала"
        },
        {
          "name": "text",
          "type": "string",
          "required": true,
          "description": "Текст сообщения"
        }
      ],
      "outputs": [
        {
          "name": "message_id",
          "type": "string",
          "description": "ID отправленного сообщения"
        }
      ]
    },
    "constraints": {
      "rate_limits": "Telegram Bot API лимитирует частоту запросов; включите retry/backoff.",
      "regions": "обычно без ограничений",
      "costs": "бесплатно",
      "data_retention": "зависит от Telegram"
    },
    "examples": [
      {
        "name": "simple_send",
        "input": {
          "chat_id": "-100...",
          "text": "Hello"
        },
        "output": {
          "message_id": "123"
        },
        "notes": "Используйте SecretRef для токена."
      }
    ],
    "common_errors": [
      {
