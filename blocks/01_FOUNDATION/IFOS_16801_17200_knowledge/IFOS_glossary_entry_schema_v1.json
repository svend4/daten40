{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Glossary Entry Schema v1",
  "type": "object",
  "required": [
    "term",
    "definition",
    "tags",
    "version",
    "updated_at"
  ],
  "properties": {
    "term": {
      "type": "string"
    },
    "definition": {
      "type": "string"
    },
    "synonyms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}