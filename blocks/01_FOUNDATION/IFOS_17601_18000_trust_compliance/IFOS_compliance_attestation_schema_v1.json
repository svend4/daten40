{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Compliance Attestation Schema v1",
  "type": "object",
  "required": [
    "att_id",
    "subject",
    "claims",
    "issuer",
    "issued_at",
    "valid_until",
    "evidence_refs",
    "version"
  ],
  "properties": {
    "att_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "status"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "license_ok",
              "sbom_present",
              "signature_valid",
              "no_secrets_in_logs",
              "pii_redaction",
              "sandbox_supported",
              "gov_mode_supported"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "warn"
            ]
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "issuer": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "key_ref": {
          "type": "string"
        },
        "method": {
          "type": "string"
        }
      }
    },
    "issued_at": {
      "type": "string"
    },
    "valid_until": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}