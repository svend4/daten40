{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Provenance Record Schema v1",
  "type": "object",
  "required": [
    "prov_id",
    "subject",
    "publisher",
    "sources",
    "inputs",
    "outputs",
    "build_env",
    "created_at",
    "version"
  ],
  "properties": {
    "prov_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "required": [
        "kind",
        "id",
        "version"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "publisher": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "key_ref": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          }
        }
      }
    },
    "build_env": {
      "type": "object",
      "properties": {
        "os": {
          "type": "string"
        },
        "toolchain": {
          "type": "string"
        },
        "container": {
          "type": "string"
        },
        "reproducible": {
          "type": "boolean"
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}