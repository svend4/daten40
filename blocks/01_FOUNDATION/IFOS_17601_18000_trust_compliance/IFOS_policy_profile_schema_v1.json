{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Policy Profile Schema v1",
  "type": "object",
  "required": [
    "profile_id",
    "name",
    "mode",
    "rules",
    "version",
    "updated_at"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "sandbox",
        "personal",
        "team",
        "b2b",
        "government"
      ]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "decision"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "network",
              "secrets",
              "pii",
              "license",
              "signature",
              "sbom",
              "webhooks",
              "storage",
              "external_api"
            ]
          },
          "decision": {
            "type": "string",
            "enum": [
              "allow",
              "deny",
              "allow_with_conditions"
            ]
          },
          "conditions": {
            "type": "object"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}