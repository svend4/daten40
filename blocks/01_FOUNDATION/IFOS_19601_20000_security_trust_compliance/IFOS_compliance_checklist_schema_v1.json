{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Compliance Checklist Schema v1",
  "type": "object",
  "required": [
    "checklist_id",
    "subject",
    "frameworks",
    "items",
    "status",
    "version",
    "updated_at"
  ],
  "properties": {
    "checklist_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "frameworks": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "gdpr",
          "soc2",
          "iso27001",
          "internal"
        ]
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "n/a",
              "warn"
            ]
          },
          "evidence_ref": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}