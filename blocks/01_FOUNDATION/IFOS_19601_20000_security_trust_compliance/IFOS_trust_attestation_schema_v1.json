{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Trust Attestation Schema v1",
  "type": "object",
  "required": [
    "attestation_id",
    "subject",
    "issuer",
    "claims",
    "evidence_refs",
    "issued_at",
    "version",
    "updated_at"
  ],
  "properties": {
    "attestation_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "issuer": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "scanner",
            "platform",
            "publisher",
            "third_party"
          ]
        },
        "id": {
          "type": "string"
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "level": {
            "type": "string",
            "enum": [
              "info",
              "warn",
              "pass",
              "fail"
            ]
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issued_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}