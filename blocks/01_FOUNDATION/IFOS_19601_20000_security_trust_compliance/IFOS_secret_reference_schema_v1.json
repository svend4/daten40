{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Reference Schema v1",
  "type": "object",
  "required": [
    "secret_ref",
    "name",
    "scope",
    "rotation",
    "created_at",
    "version",
    "updated_at"
  ],
  "properties": {
    "secret_ref": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": [
        "tenant",
        "user",
        "device"
      ]
    },
    "rotation": {
      "type": "object",
      "properties": {
        "recommended_days": {
          "type": "integer"
        },
        "last_rotated_at": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}