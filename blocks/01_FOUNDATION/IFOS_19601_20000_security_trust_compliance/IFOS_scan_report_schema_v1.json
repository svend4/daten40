{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Scan Report Schema v1",
  "type": "object",
  "required": [
    "scan_id",
    "subject",
    "scanners",
    "status",
    "vulnerabilities",
    "generated_at",
    "version",
    "updated_at"
  ],
  "properties": {
    "scan_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "scanners": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "vulnerabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "vuln_id refs"
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "critical": {
          "type": "integer"
        },
        "high": {
          "type": "integer"
        },
        "medium": {
          "type": "integer"
        },
        "low": {
          "type": "integer"
        }
      }
    },
    "generated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}