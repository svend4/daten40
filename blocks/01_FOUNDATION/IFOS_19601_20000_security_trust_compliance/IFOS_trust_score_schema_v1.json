{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Trust Score Schema v1",
  "type": "object",
  "required": [
    "trust_id",
    "subject",
    "score",
    "components",
    "recommendations",
    "version",
    "updated_at"
  ],
  "properties": {
    "trust_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "weight": {
            "type": "number"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}