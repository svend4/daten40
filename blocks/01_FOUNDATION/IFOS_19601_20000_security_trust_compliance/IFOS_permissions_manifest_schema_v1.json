{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Permissions Manifest Schema v1",
  "type": "object",
  "required": [
    "perm_id",
    "subject",
    "requested",
    "network",
    "secrets",
    "storage",
    "runtime",
    "version",
    "updated_at"
  ],
  "properties": {
    "perm_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "requested": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "deny_all",
            "allowlist"
          ]
        },
        "allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "read": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "read_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "timeouts": {
          "type": "object",
          "properties": {
            "run_seconds": {
              "type": "integer"
            },
            "install_seconds": {
              "type": "integer"
            }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu_cores": {
              "type": "number"
            },
            "ram_mb": {
              "type": "integer"
            }
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}