{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Dedupe Cluster Schema v1",
  "type": "object",
  "required": [
    "cluster_id",
    "primary",
    "duplicates",
    "confidence",
    "evidence",
    "actions",
    "version",
    "updated_at"
  ],
  "properties": {
    "cluster_id": {
      "type": "string"
    },
    "primary": {
      "type": "string"
    },
    "duplicates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actions": {
      "type": "object",
      "properties": {
        "merge_reviews": {
          "type": "boolean"
        },
        "merge_quality": {
          "type": "boolean"
        },
        "merge_incidents": {
          "type": "boolean"
        },
        "redirect_slugs": {
          "type": "boolean"
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}