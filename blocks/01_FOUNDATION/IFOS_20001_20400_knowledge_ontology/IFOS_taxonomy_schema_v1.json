{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Taxonomy Schema v1",
  "type": "object",
  "required": [
    "taxonomy_id",
    "name",
    "nodes",
    "version",
    "updated_at"
  ],
  "properties": {
    "taxonomy_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "parent_id": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}