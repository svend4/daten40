{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Evidence Record Schema v1",
  "type": "object",
  "required": [
    "evidence_record_id",
    "listing_id",
    "item_version",
    "level",
    "result",
    "checks",
    "artifacts",
    "environment",
    "created_at"
  ],
  "properties": {
    "evidence_record_id": {
      "type": "string"
    },
    "listing_id": {
      "type": "string"
    },
    "item_version": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "L0_schema",
        "L1_dry_run",
        "L2_integration",
        "L3_production"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "FAIL"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "status"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "schema_validate",
              "dry_run",
              "integration_test",
              "security_scan",
              "secret_scan"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "sha256"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "redacted": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "required": [
        "target"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "connector_versions": {
          "type": "object"
        },
        "os": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        }
      }
    },
    "signature": {
      "type": "object",
      "properties": {
        "publisher_key_id": {
          "type": "string"
        },
        "sig_alg": {
          "type": "string",
          "enum": [
            "ed25519",
            "pgp",
            "none"
          ]
        },
        "signature_b64": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "type": "string"
    }
  }
}