{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretRef Schema v1",
  "type": "object",
  "required": [
    "name",
    "ref",
    "scopes",
    "created_at"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "ref": {
      "type": "string",
      "description": "secret://ten/<tenant>/vault/<name>"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rotate_days": {
      "type": "integer"
    },
    "last_rotated_at": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  }
}