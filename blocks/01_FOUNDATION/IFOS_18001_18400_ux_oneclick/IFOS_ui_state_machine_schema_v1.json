{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UI State Machine Schema v1",
  "type": "object",
  "required": [
    "machine_id",
    "states",
    "transitions",
    "initial",
    "version"
  ],
  "properties": {
    "machine_id": {
      "type": "string"
    },
    "states": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "initial": {
      "type": "string"
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "on": {
            "type": "string"
          },
          "guard_ref": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    }
  }
}