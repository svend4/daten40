{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UI Card Schema v1",
  "type": "object",
  "required": [
    "card_id",
    "subject",
    "title",
    "summary",
    "bullets",
    "badges",
    "actions",
    "sections",
    "version",
    "updated_at"
  ],
  "properties": {
    "card_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "bullets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "badges": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "ttfs_seconds": {
          "type": "integer"
        },
        "install_success_rate": {
          "type": "number"
        },
        "evidence_score": {
          "type": "number"
        },
        "rating": {
          "type": "number"
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "help": {
            "type": "string"
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "install",
              "run",
              "view_plan",
              "undo",
              "docs",
              "tutorial",
              "troubleshoot"
            ]
          },
          "explain_ref": {
            "type": "string"
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content_ref": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}