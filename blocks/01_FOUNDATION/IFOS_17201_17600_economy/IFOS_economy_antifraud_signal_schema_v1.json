{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Economy Anti‑Fraud Signal Schema v1",
  "type": "object",
  "required": [
    "signal_id",
    "kind",
    "subject",
    "severity",
    "features",
    "generated_at",
    "method_version"
  ],
  "properties": {
    "signal_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "review_spam",
        "review_bombing",
        "affiliate_fraud",
        "usage_tamper",
        "evidence_spoofing"
      ]
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "review_id": {
          "type": "string"
        },
        "tenant_id": {
          "type": "string"
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "recommended_action": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "method_version": {
      "type": "string"
    }
  }
}