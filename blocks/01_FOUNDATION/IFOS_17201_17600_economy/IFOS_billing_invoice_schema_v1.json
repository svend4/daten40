{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Billing Invoice Schema v1",
  "type": "object",
  "required": [
    "invoice_id",
    "tenant_id",
    "currency",
    "period_start",
    "period_end",
    "line_items",
    "total",
    "status",
    "evidence_refs",
    "created_at",
    "version"
  ],
  "properties": {
    "invoice_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "currency": {
      "type": "string",
      "default": "EUR"
    },
    "period_start": {
      "type": "string"
    },
    "period_end": {
      "type": "string"
    },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "amount"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "qty": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "amount": {
            "type": "number"
          },
          "subject": {
            "type": "object"
          },
          "usage_ref": {
            "type": "string"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "tax": {
      "type": "number"
    },
    "total": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "issued",
        "paid",
        "disputed",
        "void"
      ]
    },
    "payment": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string"
        },
        "paid_at": {
          "type": "string"
        },
        "tx_ref": {
          "type": "string"
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dispute_ref": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}