{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Evidence Score Schema v1",
  "type": "object",
  "required": [
    "score_id",
    "subject",
    "score",
    "signals",
    "computed_at",
    "method_version"
  ],
  "properties": {
    "score_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "computed_at": {
      "type": "string"
    },
    "method_version": {
      "type": "string"
    }
  }
}