{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Review Schema v1",
  "type": "object",
  "required": [
    "review_id",
    "subject",
    "author",
    "stars",
    "text",
    "context",
    "verified_usage",
    "evidence_refs",
    "created_at",
    "status",
    "version"
  ],
  "properties": {
    "review_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "author": {
      "type": "object",
      "properties": {
        "tenant_id": {
          "type": "string"
        },
        "user_id": {
          "type": "string"
        },
        "reputation": {
          "type": "number"
        }
      }
    },
    "stars": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "text": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "properties": {
        "target": {
          "type": "string",
          "enum": [
            "make",
            "n8n",
            "wp",
            "native",
            "unknown"
          ]
        },
        "install_plan_id": {
          "type": "string"
        },
        "job_id": {
          "type": "string"
        },
        "use_case": {
          "type": "string"
        },
        "environment": {
          "type": "object"
        }
      }
    },
    "verified_usage": {
      "type": "boolean"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          }
        }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "published",
        "hidden",
        "flagged",
        "deleted"
      ]
    },
    "moderation": {
      "type": "object",
      "properties": {
        "flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}