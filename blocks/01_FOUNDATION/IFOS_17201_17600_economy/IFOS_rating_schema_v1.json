{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Rating Schema v1",
  "type": "object",
  "required": [
    "rating_id",
    "subject",
    "stars_avg",
    "count",
    "distribution",
    "evidence_weighted_score",
    "confidence",
    "updated_at",
    "version"
  ],
  "properties": {
    "rating_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "function",
            "recipe",
            "bundle",
            "plugin",
            "adapter"
          ]
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "stars_avg": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "distribution": {
      "type": "object",
      "properties": {
        "1": {
          "type": "integer"
        },
        "2": {
          "type": "integer"
        },
        "3": {
          "type": "integer"
        },
        "4": {
          "type": "integer"
        },
        "5": {
          "type": "integer"
        }
      }
    },
    "evidence_weighted_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "confidence": {
      "type": "object",
      "properties": {
        "low": {
          "type": "number"
        },
        "high": {
          "type": "number"
        },
        "method": {
          "type": "string"
        }
      }
    },
    "segments": {
      "type": "object",
      "description": "optional breakdown by target/domain"
    },
    "updated_at": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}