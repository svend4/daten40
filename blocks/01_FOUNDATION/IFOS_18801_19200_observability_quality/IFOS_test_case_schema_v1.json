{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Test Case Schema v1",
  "type": "object",
  "required": [
    "test_id",
    "subject",
    "kind",
    "steps",
    "assertions",
    "cleanup",
    "version",
    "updated_at"
  ],
  "properties": {
    "test_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "kind": {
      "type": "string",
      "enum": [
        "unit",
        "integration",
        "smoke",
        "regression",
        "security"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "do": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          }
        }
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "check": {
            "type": "string"
          },
          "expected": {
            "type": "string"
          }
        }
      }
    },
    "cleanup": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}