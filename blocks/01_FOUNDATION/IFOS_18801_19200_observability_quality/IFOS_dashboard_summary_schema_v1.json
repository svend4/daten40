{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Dashboard Summary Schema v1",
  "type": "object",
  "required": [
    "dashboard_id",
    "subject",
    "period",
    "headline",
    "kpis",
    "alerts",
    "version",
    "updated_at"
  ],
  "properties": {
    "dashboard_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "period": {
      "type": "string",
      "description": "e.g. last_24h, last_7d"
    },
    "headline": {
      "type": "string"
    },
    "kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "trend": {
            "type": "string",
            "enum": [
              "up",
              "down",
              "flat"
            ]
          }
        }
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": {
            "type": "string",
            "enum": [
              "info",
              "warn",
              "critical"
            ]
          },
          "message": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}