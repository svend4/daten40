{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Incident Report Schema v1",
  "type": "object",
  "required": [
    "incident_id",
    "title",
    "status",
    "severity",
    "timeline",
    "impact",
    "root_cause",
    "actions_taken",
    "prevention",
    "links",
    "version",
    "updated_at"
  ],
  "properties": {
    "incident_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "mitigating",
        "resolved",
        "postmortem_published"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "sev1",
        "sev2",
        "sev3",
        "sev4"
      ]
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "at": {
            "type": "string"
          },
          "event": {
            "type": "string"
          }
        }
      }
    },
    "impact": {
      "type": "object",
      "properties": {
        "tenants_affected": {
          "type": "integer"
        },
        "segments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "symptoms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "root_cause": {
      "type": "string"
    },
    "actions_taken": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prevention": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "release",
              "case",
              "faq",
              "docs",
              "evidence",
              "policy"
            ]
          },
          "ref": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}