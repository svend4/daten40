{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ifos.example/schema/audit-event.json",
  "title": "AuditEvent",
  "type": "object",
  "required": [
    "event_id",
    "ts",
    "actor",
    "action",
    "object",
    "result",
    "source"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "user",
            "service",
            "system"
          ]
        },
        "id": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "ip": {
          "type": "string"
        },
        "mfa": {
          "type": "boolean"
        }
      }
    },
    "action": {
      "type": "string",
      "description": "Normalized action, e.g. connector.secret.read"
    },
    "object": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "description": "connector|workflow|secret|policy|invoice|..."
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "blocked",
        "partial"
      ]
    },
    "source": {
      "type": "string",
      "description": "system emitting raw event"
    },
    "raw_ref": {
      "type": "string",
      "description": "pointer to raw log/event"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}