{
  "openapi": "3.0.0",
  "info": {
    "title": "IFOS Policy Tooling API",
    "version": "1.0.0"
  },
  "paths": {
    "/policy/simulate": {
      "post": {
        "summary": "Simulate policy evaluation without execution",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SimulationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Simulation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimulationResult"
                }
              }
            }
          }
        }
      }
    },
    "/policy/explain": {
      "post": {
        "summary": "Explain a decision for a given step/context",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExplainRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Explain output",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExplainResult"
                }
              }
            }
          }
        }
      }
    },
    "/evidence/register": {
      "get": {
        "summary": "List evidence items",
        "responses": {
          "200": {
            "description": "Evidence register",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EvidenceRegister"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SimulationRequest": {
        "type": "object",
        "properties": {
          "domain_pack": {
            "type": "string"
          },
          "bundle_id": {
            "type": "string"
          },
          "context": {
            "type": "object"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "bundle_id",
          "context"
        ]
      },
      "SimulationResult": {
        "type": "object",
        "properties": {
          "decision": {
            "type": "string"
          },
          "violations": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "trace": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ExplainRequest": {
        "type": "object",
        "properties": {
          "step_id": {
            "type": "string"
          },
          "context": {
            "type": "object"
          }
        },
        "required": [
          "step_id",
          "context"
        ]
      },
      "ExplainResult": {
        "type": "object",
        "properties": {
          "decision": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "required_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "EvidenceRegister": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}