{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaxEvent",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "jurisdiction",
    "tax_code"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "enum": [
        "sale",
        "refund",
        "adjustment"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "jurisdiction": {
      "type": "string"
    },
    "tax_code": {
      "type": "string"
    },
    "base_amount": {
      "type": "number"
    },
    "tax_amount": {
      "type": "number"
    }
  }
}