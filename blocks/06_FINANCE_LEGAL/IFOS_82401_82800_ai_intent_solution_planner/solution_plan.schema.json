{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IFOS Solution Plan",
  "type": "object",
  "required": [
    "plan_id",
    "nodes",
    "edges"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "intent": {
      "type": "object"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "capability",
          "connector",
          "operation"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "capability": {
            "type": "string"
          },
          "connector": {
            "type": "string"
          },
          "operation": {
            "type": "string"
          },
          "params": {
            "type": "object"
          },
          "scores": {
            "type": "object"
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "contract": {
            "type": "object"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "fallbacks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}