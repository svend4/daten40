{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IFOS Intent",
  "type": "object",
  "required": [
    "goal"
  ],
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 3
    },
    "context": {
      "type": "object"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "allow_connectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deny_connectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max_monthly_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "regions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "privacy_level": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        },
        "latency_target_ms": {
          "type": "integer",
          "minimum": 0
        },
        "reliability_target": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}