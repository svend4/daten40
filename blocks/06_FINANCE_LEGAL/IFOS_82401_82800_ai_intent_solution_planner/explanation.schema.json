{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IFOS Explanation Report",
  "type": "object",
  "required": [
    "plan_id",
    "steps"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "chosen",
          "rejected_top"
        ],
        "properties": {
          "node_id": {
            "type": "string"
          },
          "chosen": {
            "type": "object"
          },
          "rejected_top": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}