{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "bill_id",
    "vendor_id",
    "amount",
    "currency",
    "due_date",
    "status"
  ],
  "properties": {
    "bill_id": {
      "type": "string"
    },
    "vendor_id": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "received",
        "approved",
        "due",
        "paid",
        "closed"
      ]
    }
  }
}