{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IFOS Domain Pack Manifest",
  "type": "object",
  "required": [
    "pack_id",
    "domain",
    "version",
    "status",
    "bundles"
  ],
  "properties": {
    "pack_id": {
      "type": "string"
    },
    "domain": {
      "type": "object",
      "required": [
        "slug",
        "name"
      ],
      "properties": {
        "slug": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pilot",
        "production",
        "certified"
      ]
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "ifos_min_version": {
          "type": "string"
        },
        "required_blocks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "connectors": {
      "type": "object",
      "properties": {
        "allow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data_contracts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kpis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bundles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "bundle_id",
          "manifest_path"
        ],
        "properties": {
          "bundle_id": {
            "type": "string"
          },
          "manifest_path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    }
  }
}