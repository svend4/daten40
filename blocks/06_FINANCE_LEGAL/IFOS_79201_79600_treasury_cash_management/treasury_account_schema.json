{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "account_id",
    "type",
    "currency",
    "iban",
    "bank_name",
    "status"
  ],
  "properties": {
    "account_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "bank_account",
        "wallet",
        "virtual_account"
      ]
    },
    "currency": {
      "type": "string"
    },
    "iban": {
      "type": "string"
    },
    "bic": {
      "type": "string"
    },
    "bank_name": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "closed"
      ]
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}