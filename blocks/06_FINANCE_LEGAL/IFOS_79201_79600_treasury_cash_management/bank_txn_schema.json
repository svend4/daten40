{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "txn_id",
    "account_id",
    "amount",
    "currency",
    "booking_date",
    "value_date",
    "direction"
  ],
  "properties": {
    "txn_id": {
      "type": "string"
    },
    "account_id": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "booking_date": {
      "type": "string",
      "format": "date"
    },
    "value_date": {
      "type": "string",
      "format": "date"
    },
    "direction": {
      "type": "string",
      "enum": [
        "in",
        "out"
      ]
    },
    "counterparty_name": {
      "type": "string"
    },
    "counterparty_iban": {
      "type": "string"
    },
    "reference": {
      "type": "string"
    },
    "raw_ref": {
      "type": "string"
    }
  }
}