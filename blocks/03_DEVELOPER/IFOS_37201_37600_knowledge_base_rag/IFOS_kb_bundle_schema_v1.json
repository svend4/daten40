{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS KBBundle Schema v1",
  "type": "object",
  "required": [
    "bundle_id",
    "tenant_id",
    "name",
    "sources",
    "policies",
    "index_id",
    "version"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policies": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "index_id": {
      "type": "string"
    },
    "tags": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}