{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RAGEvalRun Schema v1",
  "type": "object",
  "required": [
    "eval_id",
    "tenant_id",
    "bundle_id",
    "questions",
    "metrics",
    "created_at",
    "version"
  ],
  "properties": {
    "eval_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}