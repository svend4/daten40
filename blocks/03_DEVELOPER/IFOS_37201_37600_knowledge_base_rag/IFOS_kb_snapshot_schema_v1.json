{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS KBSnapshot Schema v1",
  "type": "object",
  "required": [
    "snapshot_id",
    "tenant_id",
    "bundle_id",
    "created_at",
    "artifacts",
    "hashes",
    "version"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "hashes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}