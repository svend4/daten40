{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SandboxProfile Schema v1",
  "type": "object",
  "required": [
    "sandbox_id",
    "network",
    "filesystem",
    "resources",
    "restrictions",
    "version"
  ],
  "properties": {
    "sandbox_id": {
      "type": "string"
    },
    "network": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "deny_all",
            "allowlist"
          ]
        },
        "allow_domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "filesystem": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "read_only",
            "tmp_only",
            "read_write_scoped"
          ]
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "cpu_ms": {
          "type": "integer",
          "minimum": 0
        },
        "ram_mb": {
          "type": "integer",
          "minimum": 0
        },
        "timeout_sec": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "restrictions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}