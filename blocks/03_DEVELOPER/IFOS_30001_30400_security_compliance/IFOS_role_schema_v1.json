{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Role Schema v1",
  "type": "object",
  "required": [
    "role_id",
    "name",
    "permissions",
    "version"
  ],
  "properties": {
    "role_id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "enum": [
        "Viewer",
        "Operator",
        "Editor",
        "Admin"
      ]
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}