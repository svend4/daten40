{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretRef Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "name",
    "purpose",
    "access_policy",
    "rotation",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "access_policy": {
      "type": "object",
      "properties": {
        "read_roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write_roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "rotation": {
      "type": "object",
      "properties": {
        "recommended_days": {
          "type": "integer",
          "minimum": 0
        },
        "last_rotated_at": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}