{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SubscriptionPlan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "name",
    "billing_period",
    "price",
    "currency",
    "limits",
    "features",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "billing_period": {
      "type": "string",
      "enum": [
        "one_time",
        "monthly",
        "yearly"
      ]
    },
    "price": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string"
    },
    "limits": {
      "type": "object",
      "properties": {
        "seats": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "domains": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "usage": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}