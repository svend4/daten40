{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS LicenseEntitlement Schema v1",
  "type": "object",
  "required": [
    "entitlement_id",
    "owner_kind",
    "owner_id",
    "target_kind",
    "target_id",
    "type",
    "status",
    "issued_at",
    "expires_at",
    "constraints",
    "token",
    "version"
  ],
  "properties": {
    "entitlement_id": {
      "type": "string"
    },
    "owner_kind": {
      "type": "string",
      "enum": [
        "user",
        "org"
      ]
    },
    "owner_id": {
      "type": "string"
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "item",
        "bundle",
        "vitrine"
      ]
    },
    "target_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "trial",
        "subscription",
        "perpetual"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "revoked",
        "expired"
      ]
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "constraints": {
      "type": "object",
      "properties": {
        "seats": {
          "type": [
            "integer",
            "null"
          ]
        },
        "domains": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "usage_limits": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "token": {
      "type": "object",
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "jwt",
            "signed_blob",
            "api_key"
          ]
        },
        "value": {
          "type": "string"
        },
        "signature": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}