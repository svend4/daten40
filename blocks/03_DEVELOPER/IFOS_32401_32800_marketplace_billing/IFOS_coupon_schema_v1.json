{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Coupon Schema v1",
  "type": "object",
  "required": [
    "coupon_id",
    "code",
    "kind",
    "value",
    "currency",
    "active",
    "version"
  ],
  "properties": {
    "coupon_id": {
      "type": "string"
    },
    "code": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "percent",
        "fixed"
      ]
    },
    "value": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": [
        "string",
        "null"
      ]
    },
    "active": {
      "type": "boolean"
    },
    "max_redemptions": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "valid_from": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "valid_to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}