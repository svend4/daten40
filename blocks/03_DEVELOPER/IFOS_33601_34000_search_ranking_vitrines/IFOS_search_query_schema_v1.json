{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SearchQuery Schema v1",
  "type": "object",
  "required": [
    "query_id",
    "text",
    "filters",
    "sort",
    "paging",
    "context",
    "version"
  ],
  "properties": {
    "query_id": {
      "type": "string"
    },
    "text": {
      "type": [
        "string",
        "null"
      ]
    },
    "filters": {
      "type": "object",
      "additionalProperties": true
    },
    "sort": {
      "type": "object",
      "required": [
        "by"
      ],
      "properties": {
        "by": {
          "type": "string",
          "enum": [
            "relevance",
            "dq_score",
            "popularity",
            "freshness",
            "price",
            "success_rate"
          ]
        },
        "order": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ]
        }
      },
      "additionalProperties": true
    },
    "paging": {
      "type": "object",
      "required": [
        "offset",
        "limit"
      ],
      "properties": {
        "offset": {
          "type": "integer",
          "minimum": 0
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200
        }
      },
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "properties": {
        "lang": {
          "type": [
            "string",
            "null"
          ]
        },
        "platform": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "android",
            "web",
            "server",
            "docker",
            "k8s"
          ]
        },
        "policy_mode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "permissive",
            "balanced",
            "strict"
          ]
        },
        "user_role": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "novice",
            "pro",
            "dev",
            "admin"
          ]
        }
      },
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}