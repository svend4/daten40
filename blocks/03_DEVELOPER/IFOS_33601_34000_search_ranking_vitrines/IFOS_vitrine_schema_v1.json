{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vitrine Schema v1",
  "type": "object",
  "required": [
    "vitrine_id",
    "title",
    "kind",
    "criteria",
    "items",
    "updated_at",
    "version"
  ],
  "properties": {
    "vitrine_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "curated",
        "auto",
        "hybrid"
      ]
    },
    "criteria": {
      "type": "object",
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "IFOS_vitrine_item_schema_v1.json"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}