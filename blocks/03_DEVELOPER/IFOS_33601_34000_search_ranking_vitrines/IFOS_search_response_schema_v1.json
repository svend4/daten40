{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SearchResponse Schema v1",
  "type": "object",
  "required": [
    "query_id",
    "total",
    "hits",
    "facets",
    "suggestions",
    "version"
  ],
  "properties": {
    "query_id": {
      "type": "string"
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "hits": {
      "type": "array",
      "items": {
        "$ref": "IFOS_search_hit_schema_v1.json"
      }
    },
    "facets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "suggestions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}