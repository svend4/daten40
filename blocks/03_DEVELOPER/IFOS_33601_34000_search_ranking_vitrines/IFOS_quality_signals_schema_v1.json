{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS QualitySignals Schema v1",
  "type": "object",
  "required": [
    "signals_id",
    "canonical_id",
    "signals",
    "computed_at",
    "version"
  ],
  "properties": {
    "signals_id": {
      "type": "string"
    },
    "canonical_id": {
      "type": "string"
    },
    "signals": {
      "type": "object",
      "properties": {
        "dq_overall": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "trust": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "installability": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "success_rate": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "freshness_days": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "popularity": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}