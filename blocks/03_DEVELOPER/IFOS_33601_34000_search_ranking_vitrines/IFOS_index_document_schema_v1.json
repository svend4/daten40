{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS IndexDocument Schema v1",
  "type": "object",
  "required": [
    "doc_id",
    "canonical_id",
    "kind",
    "title",
    "text",
    "facets",
    "signals",
    "updated_at",
    "version"
  ],
  "properties": {
    "doc_id": {
      "type": "string"
    },
    "canonical_id": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "facets": {
      "type": "object",
      "additionalProperties": true
    },
    "signals": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}