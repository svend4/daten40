{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DedupeDecision Schema v1",
  "type": "object",
  "required": [
    "decision_id",
    "pair_id",
    "decision",
    "score",
    "reasons",
    "merge_policy",
    "version"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "pair_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "same",
        "different",
        "unsure"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "merge_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}