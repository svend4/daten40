{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Entity Schema v1",
  "type": "object",
  "required": [
    "entity_id",
    "type",
    "names",
    "external_ids",
    "features",
    "confidence",
    "version"
  ],
  "properties": {
    "entity_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "org",
        "person",
        "product",
        "location",
        "service",
        "app",
        "plugin"
      ]
    },
    "names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "external_ids": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phones": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "addresses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "identifiers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "version": {
      "type": "string"
    }
  }
}