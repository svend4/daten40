{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ValidationReport Schema v1",
  "type": "object",
  "required": [
    "report_id",
    "record_id",
    "status",
    "violations",
    "scores",
    "version"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "record_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "flagged",
        "quarantined",
        "rejected"
      ]
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "msg"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "scores": {
      "type": "object",
      "properties": {
        "completeness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "validity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "uniqueness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "freshness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "consistency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}