{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UI Card Schema v1",
  "type": "object",
  "required": [
    "card_id",
    "type",
    "title",
    "description",
    "actions",
    "risk",
    "version"
  ],
  "properties": {
    "card_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "tool",
        "workflow",
        "bundle",
        "vitrine",
        "doc"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "action_type": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              null,
              "open",
              "run",
              "install",
              "preview"
            ]
          },
          "payload": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "risk": {
      "type": "string",
      "enum": [
        "safe",
        "confirm",
        "restricted"
      ]
    },
    "links": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}