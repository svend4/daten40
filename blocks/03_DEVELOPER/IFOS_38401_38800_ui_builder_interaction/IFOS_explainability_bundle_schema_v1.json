{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ExplainabilityBundle Schema v1",
  "type": "object",
  "required": [
    "explain_id",
    "run_id",
    "citations",
    "policies",
    "decisions",
    "risks",
    "version"
  ],
  "properties": {
    "explain_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "citations": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "policies": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "decisions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "risks": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "rollback_hint": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}