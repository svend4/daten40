{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UI State Model Schema v1",
  "type": "object",
  "required": [
    "state_id",
    "tenant_id",
    "context",
    "drafts",
    "history",
    "version"
  ],
  "properties": {
    "state_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "drafts": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "history": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "links": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}