{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UI Vitrine Schema v1",
  "type": "object",
  "required": [
    "vitrine_id",
    "title",
    "cards",
    "filters",
    "onboarding",
    "version"
  ],
  "properties": {
    "vitrine_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "filters": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "onboarding": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "recommended_bundles": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}