{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UI Form Schema v1",
  "type": "object",
  "required": [
    "form_id",
    "title",
    "fields",
    "version"
  ],
  "properties": {
    "form_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "textarea",
              "select",
              "multiselect",
              "file",
              "date",
              "number",
              "toggle"
            ]
          },
          "required": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "validation": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          },
          "help": {
            "type": [
              "string",
              "null"
            ]
          },
          "default": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          },
          "options": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "depends_on": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "wizard": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}