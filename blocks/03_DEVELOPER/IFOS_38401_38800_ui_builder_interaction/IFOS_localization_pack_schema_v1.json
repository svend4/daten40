{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS LocalizationPack Schema v1",
  "type": "object",
  "required": [
    "pack_id",
    "locale",
    "strings",
    "glossary",
    "version"
  ],
  "properties": {
    "pack_id": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "strings": {
      "type": "object",
      "additionalProperties": true
    },
    "glossary": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}