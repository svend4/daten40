{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ExportRequest Schema v1",
  "type": "object",
  "required": [
    "export_id",
    "scope",
    "format",
    "requested_by",
    "status",
    "version"
  ],
  "properties": {
    "export_id": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "format": {
      "type": "string",
      "enum": [
        "json",
        "csv",
        "parquet",
        "bundle"
      ]
    },
    "options": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "requested_by": {
      "type": "string"
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "failed",
        "succeeded"
      ]
    },
    "artifact": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}