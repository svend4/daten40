{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ConsentRecord Schema v1",
  "type": "object",
  "required": [
    "consent_id",
    "subject_id",
    "purpose",
    "processors",
    "granted_at",
    "status",
    "version"
  ],
  "properties": {
    "consent_id": {
      "type": "string"
    },
    "subject_id": {
      "type": "string"
    },
    "purpose": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "processors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "granted_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "withdrawn_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "evidence": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "granted",
        "withdrawn",
        "expired"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}