{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS TrustScore Schema v1",
  "type": "object",
  "required": [
    "trust_id",
    "canonical_id",
    "score",
    "signals",
    "computed_at",
    "version"
  ],
  "properties": {
    "trust_id": {
      "type": "string"
    },
    "canonical_id": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "signals": {
      "type": "object",
      "additionalProperties": true
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}