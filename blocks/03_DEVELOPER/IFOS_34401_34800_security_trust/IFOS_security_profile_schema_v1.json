{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecurityProfile Schema v1",
  "type": "object",
  "required": [
    "profile_id",
    "tenant_id",
    "mode",
    "requirements",
    "version"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "strict",
        "balanced",
        "permissive"
      ]
    },
    "requirements": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}