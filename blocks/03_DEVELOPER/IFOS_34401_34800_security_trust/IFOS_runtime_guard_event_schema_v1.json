{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RuntimeGuardEvent Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "tenant_id",
    "canonical_id",
    "kind",
    "ts",
    "severity",
    "meta",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "canonical_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "egress_block",
        "secret_denied",
        "exec_denied",
        "resource_limit",
        "policy_violation"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "high",
        "critical"
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}