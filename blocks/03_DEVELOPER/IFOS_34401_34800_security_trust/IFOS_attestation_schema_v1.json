{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Attestation Schema v1",
  "type": "object",
  "required": [
    "attest_id",
    "artifact_ref",
    "provenance",
    "tests",
    "policy_checks",
    "created_at",
    "version"
  ],
  "properties": {
    "attest_id": {
      "type": "string"
    },
    "artifact_ref": {
      "type": "string"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "tests": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "policy_checks": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}