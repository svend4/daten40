{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ThreatModel Schema v1",
  "type": "object",
  "required": [
    "tm_id",
    "tenant_id",
    "assets",
    "threats",
    "controls",
    "version"
  ],
  "properties": {
    "tm_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "threats": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "controls": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}