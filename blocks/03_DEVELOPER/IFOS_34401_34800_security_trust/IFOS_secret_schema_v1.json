{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "tenant_id",
    "type",
    "scopes",
    "created_at",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth_token",
        "password",
        "certificate"
      ]
    },
    "provider": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "vault",
        "kms",
        "keychain",
        "env"
      ]
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ttl_hours": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "rotate_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "meta": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}