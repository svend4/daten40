{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecurityIncident Schema v1",
  "type": "object",
  "required": [
    "incident_id",
    "tenant_id",
    "type",
    "status",
    "opened_at",
    "impacted",
    "actions",
    "version"
  ],
  "properties": {
    "incident_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "malware",
        "data_leak",
        "phishing",
        "vuln_exploit",
        "policy_breach"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "mitigated",
        "closed"
      ]
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    },
    "closed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "impacted": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}