{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS BatchJob Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "tenant_id",
    "pipeline_id",
    "mode",
    "watermark",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "pipeline_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "full",
        "incremental",
        "backfill",
        "rerun_segment"
      ]
    },
    "watermark": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "params": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}