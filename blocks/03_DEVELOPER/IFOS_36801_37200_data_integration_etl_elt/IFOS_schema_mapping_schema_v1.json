{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SchemaMapping Schema v1",
  "type": "object",
  "required": [
    "mapping_id",
    "tenant_id",
    "from_dataset",
    "to_dataset",
    "rules",
    "version"
  ],
  "properties": {
    "mapping_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "from_dataset": {
      "type": "string"
    },
    "to_dataset": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}