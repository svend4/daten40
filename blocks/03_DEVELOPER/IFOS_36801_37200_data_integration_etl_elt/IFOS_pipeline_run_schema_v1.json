{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PipelineRun Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "tenant_id",
    "pipeline_id",
    "status",
    "started_at",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "pipeline_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "failed",
        "succeeded"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "metrics": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}