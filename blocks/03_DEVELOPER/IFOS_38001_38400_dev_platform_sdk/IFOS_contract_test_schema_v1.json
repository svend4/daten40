{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ContractTest Schema v1",
  "type": "object",
  "required": [
    "test_id",
    "plugin_id",
    "checks",
    "status",
    "version"
  ],
  "properties": {
    "test_id": {
      "type": "string"
    },
    "plugin_id": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "passed",
        "failed"
      ]
    },
    "report": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}