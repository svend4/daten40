{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CompatibilityMatrix Schema v1",
  "type": "object",
  "required": [
    "matrix_id",
    "entries",
    "updated_at",
    "version"
  ],
  "properties": {
    "matrix_id": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}