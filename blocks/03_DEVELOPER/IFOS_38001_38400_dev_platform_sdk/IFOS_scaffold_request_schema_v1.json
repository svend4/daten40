{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ScaffoldRequest Schema v1",
  "type": "object",
  "required": [
    "request_id",
    "type",
    "targets",
    "options",
    "version"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "connector",
        "tool_pack",
        "workflow_pack",
        "ui_pack"
      ]
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "python",
          "typescript",
          "javascript",
          "go"
        ]
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}