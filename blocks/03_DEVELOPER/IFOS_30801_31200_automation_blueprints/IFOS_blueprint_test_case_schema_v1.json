{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS BlueprintTestCase Schema v1",
  "type": "object",
  "required": [
    "test_id",
    "kind",
    "inputs",
    "expected",
    "version"
  ],
  "properties": {
    "test_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "schema",
        "dry_run",
        "golden_output",
        "contract",
        "rate_limit"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "expected": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}