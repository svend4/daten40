{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ABACPolicy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "tenant_id",
    "effect",
    "rules",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "effect": {
      "type": "string",
      "enum": [
        "allow",
        "deny"
      ]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "priority": {
      "type": [
        "integer",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}