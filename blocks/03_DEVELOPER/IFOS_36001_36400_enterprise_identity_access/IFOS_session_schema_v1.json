{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Session Schema v1",
  "type": "object",
  "required": [
    "session_id",
    "tenant_id",
    "user_id",
    "expires_at",
    "scopes",
    "version"
  ],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "device": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "ip": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}