{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS AuditEvent Schema v1",
  "type": "object",
  "required": [
    "audit_id",
    "tenant_id",
    "ts",
    "actor",
    "action",
    "resource",
    "version"
  ],
  "properties": {
    "audit_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "additionalProperties": true
    },
    "action": {
      "type": "string"
    },
    "resource": {
      "type": "object",
      "additionalProperties": true
    },
    "result": {
      "type": [
        "string",
        "null"
      ]
    },
    "meta": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}