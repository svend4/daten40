{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ApiKey Schema v1",
  "type": "object",
  "required": [
    "key_id",
    "tenant_id",
    "name",
    "scopes",
    "created_at",
    "version"
  ],
  "properties": {
    "key_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "rate_limits": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "last_used_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "rotate_policy": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}