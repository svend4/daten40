{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PublishJob Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "plugin_or_bundle_id",
    "steps",
    "status",
    "created_at",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "plugin_or_bundle_id": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "failed",
        "succeeded"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "logs_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}