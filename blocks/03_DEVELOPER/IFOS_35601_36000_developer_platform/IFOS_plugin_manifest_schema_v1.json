{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PluginManifest Schema v1",
  "type": "object",
  "required": [
    "plugin_id",
    "name",
    "version",
    "author",
    "entrypoints",
    "capabilities",
    "permissions",
    "runtimes"
  ],
  "properties": {
    "plugin_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtimes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "license": {
      "type": [
        "string",
        "null"
      ]
    },
    "version_meta": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    }
  }
}