{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS TestHarness Schema v1",
  "type": "object",
  "required": [
    "harness_id",
    "suite",
    "scenarios",
    "version"
  ],
  "properties": {
    "harness_id": {
      "type": "string"
    },
    "suite": {
      "type": "string"
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "mocks": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}