{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DQScore Schema v1",
  "type": "object",
  "required": [
    "dq_id",
    "canonical_id",
    "scores",
    "computed_at",
    "version"
  ],
  "properties": {
    "dq_id": {
      "type": "string"
    },
    "canonical_id": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "required": [
        "overall"
      ],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "completeness": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "freshness": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "trust": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "installability": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "docs_quality": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}