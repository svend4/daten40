{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS MergeDecision Schema v1",
  "type": "object",
  "required": [
    "decision_id",
    "proposal_id",
    "result",
    "decided_by",
    "decided_at",
    "reason",
    "version"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "proposal_id": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": [
        "merged",
        "rejected",
        "deferred"
      ]
    },
    "decided_by": {
      "type": "string",
      "enum": [
        "auto",
        "human",
        "admin"
      ]
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "effects": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}