{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Conflict Schema v1",
  "type": "object",
  "required": [
    "conflict_id",
    "a_id",
    "b_id",
    "kind",
    "fields",
    "severity",
    "version"
  ],
  "properties": {
    "conflict_id": {
      "type": "string"
    },
    "a_id": {
      "type": "string"
    },
    "b_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "license",
        "author",
        "pricing",
        "capabilities",
        "artifacts",
        "docs",
        "source"
      ]
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "detail": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}