{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Fingerprint Schema v1",
  "type": "object",
  "required": [
    "fp_id",
    "canonical_id",
    "kind",
    "value",
    "strength",
    "version"
  ],
  "properties": {
    "fp_id": {
      "type": "string"
    },
    "canonical_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "url",
        "code",
        "name",
        "capability",
        "io",
        "artifact"
      ]
    },
    "value": {
      "type": "string"
    },
    "strength": {
      "type": "string",
      "enum": [
        "weak",
        "medium",
        "strong"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}