{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CanonicalItem Schema v1",
  "type": "object",
  "required": [
    "canonical_id",
    "title",
    "kind",
    "capabilities",
    "inputs",
    "outputs",
    "artifacts",
    "deps",
    "attribution",
    "dq_score",
    "version"
  ],
  "properties": {
    "canonical_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "wp_plugin",
        "make_scenario",
        "npm_pkg",
        "python_pkg",
        "container_image",
        "api",
        "template",
        "bundle"
      ]
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "deps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "aliases": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "attribution": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "dq_score": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}