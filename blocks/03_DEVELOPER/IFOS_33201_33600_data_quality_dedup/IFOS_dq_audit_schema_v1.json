{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DQAudit Schema v1",
  "type": "object",
  "required": [
    "audit_id",
    "action",
    "actor",
    "ts",
    "targets",
    "meta",
    "version"
  ],
  "properties": {
    "audit_id": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "id"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}