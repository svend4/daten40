{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Attribution Schema v1",
  "type": "object",
  "required": [
    "attr_id",
    "canonical_id",
    "field",
    "source_id",
    "raw_id",
    "retrieved_at",
    "confidence",
    "version"
  ],
  "properties": {
    "attr_id": {
      "type": "string"
    },
    "canonical_id": {
      "type": "string"
    },
    "field": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "raw_id": {
      "type": "string"
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}