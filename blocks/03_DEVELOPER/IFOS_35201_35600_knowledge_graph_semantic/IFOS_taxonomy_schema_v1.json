{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Taxonomy Schema v1",
  "type": "object",
  "required": [
    "taxonomy_id",
    "root",
    "nodes",
    "version"
  ],
  "properties": {
    "taxonomy_id": {
      "type": "string"
    },
    "root": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "parent",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "parent": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}