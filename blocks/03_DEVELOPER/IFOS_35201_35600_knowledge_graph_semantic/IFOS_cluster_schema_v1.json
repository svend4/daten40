{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Cluster Schema v1",
  "type": "object",
  "required": [
    "cluster_id",
    "title",
    "members",
    "labels",
    "version"
  ],
  "properties": {
    "cluster_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "members": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "labels": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "centroid": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "number"
      }
    },
    "use_cases": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}