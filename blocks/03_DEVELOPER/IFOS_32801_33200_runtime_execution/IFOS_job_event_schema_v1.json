{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS JobEvent Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "job_id",
    "queue_id",
    "status",
    "occurred_at",
    "meta",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "queue_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "retrying",
        "canceled"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}