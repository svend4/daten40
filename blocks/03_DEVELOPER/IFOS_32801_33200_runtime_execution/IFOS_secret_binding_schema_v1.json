{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretBinding Schema v1",
  "type": "object",
  "required": [
    "binding_id",
    "secret_id",
    "inject_as",
    "target",
    "redaction",
    "version"
  ],
  "properties": {
    "binding_id": {
      "type": "string"
    },
    "secret_id": {
      "type": "string"
    },
    "inject_as": {
      "type": "string",
      "enum": [
        "env",
        "file",
        "header",
        "mount"
      ]
    },
    "target": {
      "type": "object",
      "required": [
        "key"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "redaction": {
      "type": "object",
      "properties": {
        "mask_in_logs": {
          "type": "boolean"
        },
        "mask_pattern": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}