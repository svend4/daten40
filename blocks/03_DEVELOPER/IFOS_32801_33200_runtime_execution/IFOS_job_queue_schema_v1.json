{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS JobQueue Schema v1",
  "type": "object",
  "required": [
    "queue_id",
    "kind",
    "concurrency",
    "priorities",
    "version"
  ],
  "properties": {
    "queue_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "install",
        "run",
        "update",
        "rollback"
      ]
    },
    "concurrency": {
      "type": "integer",
      "minimum": 1
    },
    "priorities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}