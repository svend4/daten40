{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RuntimeEnvironment Schema v1",
  "type": "object",
  "required": [
    "env_id",
    "kind",
    "resources",
    "runtimes",
    "capabilities",
    "network",
    "filesystem",
    "version"
  ],
  "properties": {
    "env_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "local",
        "docker_compose",
        "kubernetes",
        "vm_micro",
        "wasm",
        "android_termux",
        "managed_cloud"
      ]
    },
    "resources": {
      "type": "object",
      "properties": {
        "cpu_cores": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "ram_mb": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "disk_mb": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "timeout_sec": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "runtimes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "node",
              "python",
              "php",
              "java",
              "dotnet",
              "bash",
              "wasm"
            ]
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "allowlist_domains": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "denylist_domains": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "max_bandwidth_kbps": {
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "filesystem": {
      "type": "object",
      "properties": {
        "read_only": {
          "type": "boolean"
        },
        "tmp_mb": {
          "type": [
            "integer",
            "null"
          ]
        },
        "mounts": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}