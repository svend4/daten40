{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ExecutionPolicy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "level",
    "rules",
    "limits",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "platform",
        "org",
        "user"
      ]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "action"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "network_domain",
              "connector",
              "capability",
              "data_class",
              "dangerous_op"
            ]
          },
          "action": {
            "type": "string",
            "enum": [
              "allow",
              "deny",
              "require_confirm"
            ]
          },
          "match": {
            "type": "object",
            "additionalProperties": true
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "limits": {
      "type": "object",
      "properties": {
        "max_runs_per_day": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "max_cost_per_day": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "max_usage": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}