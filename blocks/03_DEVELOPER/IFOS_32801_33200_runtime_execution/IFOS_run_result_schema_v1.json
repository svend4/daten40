{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RunResult Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "status",
    "started_at",
    "ended_at",
    "exit_code",
    "outputs",
    "report",
    "health",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "canceled"
      ]
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "report": {
      "type": "object",
      "properties": {
        "log_stream_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "artifacts": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "cost": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "health": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}