{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretRef Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "kind",
    "label",
    "scope",
    "provider",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth_token",
        "password",
        "cert",
        "webhook_secret"
      ]
    },
    "label": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": [
        "user",
        "org",
        "runtime_env"
      ]
    },
    "provider": {
      "type": "string",
      "enum": [
        "local_encrypted",
        "vault",
        "android_keystore",
        "k8s_secret",
        "managed_platform"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}