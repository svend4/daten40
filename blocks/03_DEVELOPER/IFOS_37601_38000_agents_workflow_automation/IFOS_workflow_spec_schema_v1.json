{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS WorkflowSpec Schema v1",
  "type": "object",
  "required": [
    "workflow_id",
    "tenant_id",
    "name",
    "steps",
    "version"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "tool_ref",
          "inputs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "tool_ref": {
            "type": "string"
          },
          "inputs": {
            "type": "object",
            "additionalProperties": true
          },
          "depends_on": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          },
          "on_error": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          },
          "when": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}