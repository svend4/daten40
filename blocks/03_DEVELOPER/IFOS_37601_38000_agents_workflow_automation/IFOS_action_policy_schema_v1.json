{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ActionPolicy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "tenant_id",
    "rules",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "effect"
        ],
        "properties": {
          "effect": {
            "type": "string",
            "enum": [
              "allow",
              "deny",
              "require_approval"
            ]
          },
          "tool_match": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          },
          "scope_match": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          },
          "data_match": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          },
          "limits": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}