{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ExecutionRun Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "tenant_id",
    "workflow_id",
    "status",
    "started_at",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "failed",
        "succeeded",
        "paused_for_approval"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "step_results": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}