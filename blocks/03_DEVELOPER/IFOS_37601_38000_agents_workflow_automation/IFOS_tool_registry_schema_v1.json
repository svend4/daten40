{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ToolRegistry Schema v1",
  "type": "object",
  "required": [
    "registry_id",
    "tenant_id",
    "tools",
    "bundles",
    "version"
  ],
  "properties": {
    "registry_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bundles": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "compat": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}