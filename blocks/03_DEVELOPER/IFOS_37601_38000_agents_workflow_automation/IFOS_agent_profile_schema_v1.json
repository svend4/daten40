{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS AgentProfile Schema v1",
  "type": "object",
  "required": [
    "agent_id",
    "tenant_id",
    "name",
    "goals",
    "permissions",
    "constraints",
    "version"
  ],
  "properties": {
    "agent_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "goals": {
      "type": "object",
      "additionalProperties": true
    },
    "permissions": {
      "type": "object",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "preferences": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}