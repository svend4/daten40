{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PlanSpec Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "tenant_id",
    "task_id",
    "steps",
    "checks",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "checks": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "requires_approvals": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}