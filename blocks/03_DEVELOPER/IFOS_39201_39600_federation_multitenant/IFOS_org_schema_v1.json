{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Org Schema v1",
  "type": "object",
  "required": [
    "org_id",
    "name",
    "status",
    "created_at",
    "version"
  ],
  "properties": {
    "org_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended"
      ]
    },
    "billing_profile": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}