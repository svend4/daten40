{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SyncJob Schema v1",
  "type": "object",
  "required": [
    "sync_id",
    "direction",
    "scope",
    "peer_id",
    "status",
    "created_at",
    "version"
  ],
  "properties": {
    "sync_id": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": [
        "pull",
        "push",
        "bidirectional"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "peer_id": {
      "type": "string"
    },
    "schedule": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "integrity": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "failed",
        "succeeded"
      ]
    },
    "report": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}