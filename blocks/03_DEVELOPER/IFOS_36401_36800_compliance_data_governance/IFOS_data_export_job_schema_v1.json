{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DataExportJob Schema v1",
  "type": "object",
  "required": [
    "export_id",
    "tenant_id",
    "request_ref",
    "scope",
    "format",
    "status",
    "created_at",
    "version"
  ],
  "properties": {
    "export_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "request_ref": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "format": {
      "type": "string",
      "enum": [
        "json",
        "csv",
        "parquet",
        "zip"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "failed",
        "done"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "result_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}