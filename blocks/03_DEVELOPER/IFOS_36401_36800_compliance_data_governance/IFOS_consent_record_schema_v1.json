{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ConsentRecord Schema v1",
  "type": "object",
  "required": [
    "consent_id",
    "tenant_id",
    "subject",
    "purpose_id",
    "status",
    "ts",
    "version"
  ],
  "properties": {
    "consent_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "additionalProperties": true
    },
    "purpose_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "granted",
        "revoked"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "meta": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}