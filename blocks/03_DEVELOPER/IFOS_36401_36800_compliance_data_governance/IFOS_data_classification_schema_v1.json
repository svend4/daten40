{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DataClassification Schema v1",
  "type": "object",
  "required": [
    "class_id",
    "name",
    "level",
    "labels",
    "version"
  ],
  "properties": {
    "class_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handling": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}