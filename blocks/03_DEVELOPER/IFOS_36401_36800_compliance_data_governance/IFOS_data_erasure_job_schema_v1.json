{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DataErasureJob Schema v1",
  "type": "object",
  "required": [
    "erasure_id",
    "tenant_id",
    "request_ref",
    "scope",
    "status",
    "created_at",
    "version"
  ],
  "properties": {
    "erasure_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "request_ref": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "failed",
        "done",
        "blocked_legal_hold"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "report_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}