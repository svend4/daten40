{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ResourceClass Schema v1",
  "type": "object",
  "required": [
    "resource_id",
    "name",
    "unit",
    "version"
  ],
  "properties": {
    "resource_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "unit": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}