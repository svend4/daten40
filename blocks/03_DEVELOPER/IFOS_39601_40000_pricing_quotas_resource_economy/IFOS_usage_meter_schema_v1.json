{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UsageMeter Schema v1",
  "type": "object",
  "required": [
    "meter_id",
    "ts",
    "tenant_id",
    "run_id",
    "resources",
    "status",
    "version"
  ],
  "properties": {
    "meter_id": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "user_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "asset": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "run_id": {
      "type": "string"
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "resource_id",
          "quantity"
        ],
        "properties": {
          "resource_id": {
            "type": "string"
          },
          "quantity": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "canceled"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}