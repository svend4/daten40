{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Invoice Schema v1",
  "type": "object",
  "required": [
    "invoice_id",
    "tenant_id",
    "period",
    "lines",
    "total",
    "currency",
    "status",
    "version"
  ],
  "properties": {
    "invoice_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "period": {
      "type": "object",
      "additionalProperties": true
    },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "description",
          "amount"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "details": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "issued",
        "paid",
        "void"
      ]
    },
    "artifacts": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}