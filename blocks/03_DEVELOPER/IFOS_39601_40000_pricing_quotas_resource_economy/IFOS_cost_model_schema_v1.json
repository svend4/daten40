{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CostModel Schema v1",
  "type": "object",
  "required": [
    "cost_model_id",
    "asset",
    "components",
    "currency",
    "version"
  ],
  "properties": {
    "cost_model_id": {
      "type": "string"
    },
    "asset": {
      "type": "object",
      "additionalProperties": true
    },
    "currency": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "amount"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "fixed",
              "variable",
              "overhead",
              "risk"
            ]
          },
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}