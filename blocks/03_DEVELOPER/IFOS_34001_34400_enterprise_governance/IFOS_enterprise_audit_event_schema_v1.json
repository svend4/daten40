{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Enterprise AuditEvent Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "tenant_id",
    "actor",
    "action",
    "ts",
    "targets",
    "result",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "org_unit_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "success",
        "fail"
      ]
    },
    "meta": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}