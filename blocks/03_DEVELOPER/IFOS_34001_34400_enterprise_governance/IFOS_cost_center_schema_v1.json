{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CostCenter Schema v1",
  "type": "object",
  "required": [
    "cc_id",
    "tenant_id",
    "name",
    "owner",
    "version"
  ],
  "properties": {
    "cc_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "org_unit_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "tags": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}