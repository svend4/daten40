{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ComplianceReport Schema v1",
  "type": "object",
  "required": [
    "report_id",
    "tenant_id",
    "period",
    "findings",
    "generated_at",
    "version"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "period": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string",
          "format": "date-time"
        },
        "to": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}