{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Permission Schema v1",
  "type": "object",
  "required": [
    "perm_id",
    "name",
    "scope",
    "version"
  ],
  "properties": {
    "perm_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": [
        "tenant",
        "org_unit",
        "project",
        "resource"
      ]
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}