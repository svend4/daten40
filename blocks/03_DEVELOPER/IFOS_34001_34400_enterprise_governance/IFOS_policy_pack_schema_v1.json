{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PolicyPack Schema v1",
  "type": "object",
  "required": [
    "pack_id",
    "tenant_id",
    "name",
    "policies",
    "version"
  ],
  "properties": {
    "pack_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}