{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Policy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "tenant_id",
    "name",
    "mode",
    "rules",
    "enabled",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "strict",
        "balanced",
        "permissive"
      ]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "enabled": {
      "type": "boolean"
    },
    "applies_to": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}