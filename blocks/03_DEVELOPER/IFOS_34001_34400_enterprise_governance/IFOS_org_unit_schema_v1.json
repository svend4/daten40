{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS OrgUnit Schema v1",
  "type": "object",
  "required": [
    "org_unit_id",
    "tenant_id",
    "name",
    "path",
    "created_at",
    "version"
  ],
  "properties": {
    "org_unit_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "parent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "tags": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}