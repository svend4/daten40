{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SLA Schema v1",
  "type": "object",
  "required": [
    "sla_id",
    "tenant_id",
    "name",
    "commitments",
    "version"
  ],
  "properties": {
    "sla_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "commitments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "penalties": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}