{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RollbackPlan Schema v1",
  "type": "object",
  "required": [
    "rb_id",
    "canonical_id",
    "stable_version",
    "steps",
    "version"
  ],
  "properties": {
    "rb_id": {
      "type": "string"
    },
    "canonical_id": {
      "type": "string"
    },
    "stable_version": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data_migrations": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}