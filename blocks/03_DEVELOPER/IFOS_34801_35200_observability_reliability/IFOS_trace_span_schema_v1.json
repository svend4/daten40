{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS TraceSpan Schema v1",
  "type": "object",
  "required": [
    "span_id",
    "trace_id",
    "name",
    "start_ts",
    "end_ts",
    "status",
    "tenant_id",
    "version"
  ],
  "properties": {
    "span_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": "string"
    },
    "start_ts": {
      "type": "string",
      "format": "date-time"
    },
    "end_ts": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error"
      ]
    },
    "tenant_id": {
      "type": "string"
    },
    "attributes": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}