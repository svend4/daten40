{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RankingRequest Schema v1",
  "type": "object",
  "required": [
    "request_id",
    "query",
    "filters",
    "context",
    "version"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "filters": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "properties": {
        "platform": {
          "type": [
            "string",
            "null"
          ]
        },
        "os": {
          "type": [
            "string",
            "null"
          ]
        },
        "open_source_only": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "self_hosted_only": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}