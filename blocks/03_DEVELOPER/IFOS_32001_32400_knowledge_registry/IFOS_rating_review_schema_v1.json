{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RatingReview Schema v1",
  "type": "object",
  "required": [
    "review_id",
    "item_id",
    "rating",
    "text",
    "environment",
    "proof",
    "created_at",
    "version"
  ],
  "properties": {
    "review_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "text": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "environment": {
      "type": "object",
      "properties": {
        "platform": {
          "type": "string"
        },
        "platform_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "os": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "proof": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "install_log_hash",
            "run_log_hash",
            "receipt",
            "manual"
          ]
        },
        "hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "moderation": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "approved",
        "rejected",
        "quarantined"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}