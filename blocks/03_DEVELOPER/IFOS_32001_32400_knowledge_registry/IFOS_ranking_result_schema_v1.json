{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RankingResult Schema v1",
  "type": "object",
  "required": [
    "request_id",
    "results",
    "generated_at",
    "version"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "score"
        ],
        "properties": {
          "item_id": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "explain": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}