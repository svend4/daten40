{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DependencyGraph Schema v1",
  "type": "object",
  "required": [
    "graph_id",
    "root_item_id",
    "nodes",
    "edges",
    "version"
  ],
  "properties": {
    "graph_id": {
      "type": "string"
    },
    "root_item_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "item",
              "runtime",
              "service",
              "credential",
              "file"
            ]
          },
          "meta": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "kind"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "depends_on",
              "optional",
              "conflicts_with",
              "replaces"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}