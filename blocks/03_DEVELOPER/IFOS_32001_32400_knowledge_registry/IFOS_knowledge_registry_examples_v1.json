  "install_recipe": {
    "recipe_id": "recipe.r.6k09751kk14n",
    "item_id": "item.wp.zorxzqg9dwnw",
    "steps": [
      {
        "op": "download",
        "params": {
          "artifact": "git",
          "url": "https://github.com/example/wp-pdf-text"
        }
      },
      {
        "op": "wp_plugin_install",
        "params": {
          "path": "wp-pdf-text"
        }
      },
      {
        "op": "set_env",
        "params": {
          "key": "PDF_TEXT_MAX_MB",
          "value": "10"
        }
      },
      {
        "op": "run_command",
        "params": {
          "cmd": "wp plugin activate wp-pdf-text"
        }
      }
    ],
    "health_checks": [
      {
        "kind": "http",
        "params": {
          "url": "http://localhost/wp-json/wp-pdf-text/health"
