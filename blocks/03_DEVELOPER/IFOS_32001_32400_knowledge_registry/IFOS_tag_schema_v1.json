{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Tag Schema v1",
  "type": "object",
  "required": [
    "tag",
    "description",
    "version"
  ],
  "properties": {
    "tag": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "synonyms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}