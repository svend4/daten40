{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Function Cluster Schema v1",
  "type": "object",
  "required": [
    "cluster_id",
    "name",
    "job_story",
    "members",
    "recommended_macros",
    "version"
  ],
  "properties": {
    "cluster_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "job_story": {
      "type": "string"
    },
    "members": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_macros": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}