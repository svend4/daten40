  "macro": {
    "macro_id": "mac.m.qorjl1d4b237",
    "name": "Weekly News Conference Digest",
    "level": "standard",
    "intent": "Собрать новости из RSS + dedup + выделить топ + опубликовать в конференц-витрине.",
    "prerequisites": [
      "connector.rss",
      "storage.vault",
      "vitrine.conference_mode"
    ],
    "steps": [
      {
        "module": "rss.fetch",
        "params": {
          "sources": "list",
          "window": "7d"
        }
      },
      {
        "module": "dedup.run",
        "params": {
          "key": "url+title"
        }
      },
      {
        "module": "rank.run",
        "params": {
          "signals": "recency+source_trust"
        }
      },
      {
        "module": "vitrine.publish",
        "params": {
          "mode": "conference"
        }
      }
    ],
    "error_handling": [
      "retry:3",
      "timeout:30s",
      "fallback:store_raw"
    ],
    "outputs": [
      "vitrine:news_conference",
      "vault:raw_dump"
    ],
    "version": "1.0.0"
  },
