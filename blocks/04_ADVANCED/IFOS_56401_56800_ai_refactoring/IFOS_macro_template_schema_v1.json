{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Macro Template Schema v1",
  "type": "object",
  "required": [
    "macro_id",
    "name",
    "level",
    "intent",
    "steps",
    "version"
  ],
  "properties": {
    "macro_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "basic",
        "standard",
        "pro"
      ]
    },
    "intent": {
      "type": "string"
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "error_handling": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}