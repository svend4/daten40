{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Metric Schema v1",
  "type": "object",
  "required": [
    "metric_id",
    "name",
    "type",
    "direction",
    "version"
  ],
  "properties": {
    "metric_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "runtime",
        "quality",
        "governance"
      ]
    },
    "direction": {
      "type": "string",
      "enum": [
        "higher_is_better",
        "lower_is_better"
      ]
    },
    "unit": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}