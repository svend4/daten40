{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Event Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "type",
    "entity_id",
    "payload",
    "ts",
    "dedup_key",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "entity_id": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "dedup_key": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}