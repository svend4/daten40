{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CanonicalRecord Schema v1",
  "type": "object",
  "required": [
    "entity_id",
    "canonical",
    "sources",
    "trust",
    "version"
  ],
  "properties": {
    "entity_id": {
      "type": "string"
    },
    "canonical": {
      "type": "object",
      "additionalProperties": true
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trust": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}