{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS QualityRule Schema v1",
  "type": "object",
  "required": [
    "rule_id",
    "entity_type",
    "rule",
    "severity",
    "version"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "entity_type": {
      "type": "string"
    },
    "rule": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "error"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}