{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ApprovalGate Schema v1",
  "type": "object",
  "required": [
    "gate_id",
    "rules",
    "roles",
    "audit",
    "version"
  ],
  "properties": {
    "gate_id": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}