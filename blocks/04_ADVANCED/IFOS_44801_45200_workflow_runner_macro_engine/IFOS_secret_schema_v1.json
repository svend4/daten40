{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Schema v1",
  "type": "object",
  "required": [
    "secret_id",
    "name",
    "type",
    "scope",
    "created_at",
    "version"
  ],
  "properties": {
    "secret_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth_token",
        "password",
        "certificate"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "user",
        "team",
        "tenant",
        "run"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "rotates_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}