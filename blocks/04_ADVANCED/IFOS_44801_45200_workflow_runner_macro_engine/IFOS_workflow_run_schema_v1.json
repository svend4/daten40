{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS WorkflowRun Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "template_id",
    "engine",
    "params",
    "state",
    "ts",
    "tenant",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "engine": {
      "type": "string",
      "enum": [
        "make",
        "n8n",
        "node_red",
        "custom"
      ]
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    },
    "state": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "done",
        "error",
        "cancelled"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "tenant": {
      "type": "string"
    },
    "logs_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifacts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}