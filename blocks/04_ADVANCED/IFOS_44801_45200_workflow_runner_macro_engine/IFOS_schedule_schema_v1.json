{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Schedule Schema v1",
  "type": "object",
  "required": [
    "schedule_id",
    "type",
    "expr",
    "timezone",
    "enabled",
    "version"
  ],
  "properties": {
    "schedule_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "cron",
        "rrule",
        "event"
      ]
    },
    "expr": {
      "type": "string"
    },
    "timezone": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "version": {
      "type": "string"
    }
  }
}