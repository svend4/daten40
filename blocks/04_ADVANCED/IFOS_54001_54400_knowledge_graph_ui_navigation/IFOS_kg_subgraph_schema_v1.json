{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Subgraph Schema v1",
  "type": "object",
  "required": [
    "subgraph_id",
    "nodes",
    "edges",
    "version"
  ],
  "properties": {
    "subgraph_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/edge"
      }
    },
    "version": {
      "type": "string"
    }
  },
  "definitions": {
    "node": {
      "type": "object"
    },
    "edge": {
      "type": "object"
    }
  }
}