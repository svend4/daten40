{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Graph View Schema v1",
  "type": "object",
  "required": [
    "view_id",
    "name",
    "mode",
    "filters",
    "query_id",
    "layout",
    "version"
  ],
  "properties": {
    "view_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "map",
        "list",
        "matrix",
        "timeline",
        "impact"
      ]
    },
    "filters": {
      "type": "object",
      "additionalProperties": true
    },
    "query_id": {
      "type": "string"
    },
    "layout": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}