{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Knowledge Graph Node Schema v1",
  "type": "object",
  "required": [
    "node_id",
    "node_type",
    "title",
    "meta",
    "version"
  ],
  "properties": {
    "node_id": {
      "type": "string"
    },
    "node_type": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}