{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Impact Report Schema v1",
  "type": "object",
  "required": [
    "report_id",
    "target",
    "summary",
    "impacted",
    "risk",
    "required_tests",
    "version"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "impacted": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "required_tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}