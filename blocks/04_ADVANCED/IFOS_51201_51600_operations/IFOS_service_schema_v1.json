{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Service Schema v1",
  "type": "object",
  "required": [
    "service_id",
    "name",
    "owner",
    "bundles",
    "targets",
    "version"
  ],
  "properties": {
    "service_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "bundles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}