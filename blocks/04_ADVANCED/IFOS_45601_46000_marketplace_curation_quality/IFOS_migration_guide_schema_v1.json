{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS MigrationGuide Schema v1",
  "type": "object",
  "required": [
    "guide_id",
    "item_id",
    "from",
    "to",
    "steps",
    "version"
  ],
  "properties": {
    "guide_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}