{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Review Schema v1",
  "type": "object",
  "required": [
    "review_id",
    "item_id",
    "author",
    "verified",
    "rating",
    "pros",
    "cons",
    "context",
    "ts",
    "version"
  ],
  "properties": {
    "review_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "author": {
      "type": "object",
      "additionalProperties": true
    },
    "verified": {
      "type": "boolean"
    },
    "rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "pros": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}