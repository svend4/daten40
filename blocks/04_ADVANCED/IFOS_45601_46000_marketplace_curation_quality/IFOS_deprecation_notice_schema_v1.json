{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DeprecationNotice Schema v1",
  "type": "object",
  "required": [
    "notice_id",
    "item_id",
    "sunset_at",
    "reason",
    "replacement",
    "version"
  ],
  "properties": {
    "notice_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "sunset_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string"
    },
    "replacement": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}