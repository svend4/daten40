{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS LegalHold Schema v1",
  "type": "object",
  "required": [
    "hold_id",
    "scope",
    "reason",
    "status",
    "ts",
    "version"
  ],
  "properties": {
    "hold_id": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": true
    },
    "reason": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "released"
      ]
    },
    "requested_by": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}