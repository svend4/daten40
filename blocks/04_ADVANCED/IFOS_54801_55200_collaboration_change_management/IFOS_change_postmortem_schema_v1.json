{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Postmortem Schema v1",
  "type": "object",
  "required": [
    "postmortem_id",
    "incident_id",
    "root_cause_ref",
    "lessons",
    "actions",
    "version"
  ],
  "properties": {
    "postmortem_id": {
      "type": "string"
    },
    "incident_id": {
      "type": "string"
    },
    "root_cause_ref": {
      "type": "string"
    },
    "lessons": {
      "type": "object",
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}