{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Rollout Schema v1",
  "type": "object",
  "required": [
    "rollout_id",
    "release_id",
    "strategy",
    "canary_pct",
    "status",
    "success_criteria",
    "rollback_rules",
    "version"
  ],
  "properties": {
    "rollout_id": {
      "type": "string"
    },
    "release_id": {
      "type": "string"
    },
    "strategy": {
      "type": "string",
      "enum": [
        "all_at_once",
        "canary",
        "staged_by_tenant"
      ]
    },
    "canary_pct": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "running",
        "done",
        "aborted"
      ]
    },
    "success_criteria": {
      "type": "object",
      "additionalProperties": true
    },
    "rollback_rules": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}