{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Incident Schema v1",
  "type": "object",
  "required": [
    "incident_id",
    "severity",
    "summary",
    "affected",
    "ts_start",
    "status",
    "version"
  ],
  "properties": {
    "incident_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "S1",
        "S2",
        "S3",
        "S4"
      ]
    },
    "summary": {
      "type": "string"
    },
    "affected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ts_start": {
      "type": "string",
      "format": "date-time"
    },
    "ts_end": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "mitigated",
        "closed"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}