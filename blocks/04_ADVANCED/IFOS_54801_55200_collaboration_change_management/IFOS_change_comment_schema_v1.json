{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Comment Schema v1",
  "type": "object",
  "required": [
    "comment_id",
    "object_ref",
    "author",
    "body",
    "ts",
    "status",
    "version"
  ],
  "properties": {
    "comment_id": {
      "type": "string"
    },
    "object_ref": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "resolved"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}