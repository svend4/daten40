{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Dashboard Schema v1",
  "type": "object",
  "required": [
    "dashboard_id",
    "name",
    "widgets",
    "version"
  ],
  "properties": {
    "dashboard_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "widgets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}