{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Analytics Metric Schema v1",
  "type": "object",
  "required": [
    "metric_id",
    "name",
    "value",
    "unit",
    "window",
    "ts",
    "version"
  ],
  "properties": {
    "metric_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "window": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}