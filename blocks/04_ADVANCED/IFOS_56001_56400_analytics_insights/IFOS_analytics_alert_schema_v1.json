{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Alert Schema v1",
  "type": "object",
  "required": [
    "alert_id",
    "rule",
    "status",
    "ts",
    "version"
  ],
  "properties": {
    "alert_id": {
      "type": "string"
    },
    "rule": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "fired",
        "resolved"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}