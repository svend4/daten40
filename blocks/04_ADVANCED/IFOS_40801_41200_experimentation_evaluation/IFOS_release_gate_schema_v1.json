{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ReleaseGate Schema v1",
  "type": "object",
  "required": [
    "gate_id",
    "target",
    "conditions",
    "decision",
    "ts",
    "version"
  ],
  "properties": {
    "gate_id": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "additionalProperties": true
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "metric",
          "op",
          "value"
        ],
        "properties": {
          "metric": {
            "type": "string"
          },
          "op": {
            "type": "string",
            "enum": [
              "<",
              "<=",
              "==",
              ">=",
              ">"
            ]
          },
          "value": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "block",
        "rollback",
        "require_approval"
      ]
    },
    "evidence_refs": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}