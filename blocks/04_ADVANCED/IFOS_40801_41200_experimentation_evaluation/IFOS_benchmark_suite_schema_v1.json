{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS BenchmarkSuite Schema v1",
  "type": "object",
  "required": [
    "suite_id",
    "name",
    "cases",
    "baseline",
    "version"
  ],
  "properties": {
    "suite_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}