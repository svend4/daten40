{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS EvaluationEvent Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "ts",
    "tenant_id",
    "experiment_id",
    "variant_id",
    "name",
    "payload",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "experiment_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "variant_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}