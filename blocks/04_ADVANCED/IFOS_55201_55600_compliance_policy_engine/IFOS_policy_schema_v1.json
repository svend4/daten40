{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Policy Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "name",
    "version",
    "rules"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}