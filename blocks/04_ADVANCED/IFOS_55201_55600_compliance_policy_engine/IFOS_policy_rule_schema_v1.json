{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Policy Rule Schema v1",
  "type": "object",
  "required": [
    "rule_id",
    "when",
    "if",
    "then",
    "severity",
    "version"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "when": {
      "type": "string"
    },
    "if": {
      "type": "string"
    },
    "then": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "block"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}