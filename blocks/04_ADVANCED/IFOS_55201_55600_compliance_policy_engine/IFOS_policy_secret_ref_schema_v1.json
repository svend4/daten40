{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Secret Reference Schema v1",
  "type": "object",
  "required": [
    "secret_ref",
    "provider",
    "version"
  ],
  "properties": {
    "secret_ref": {
      "type": "string"
    },
    "provider": {
      "type": "string",
      "enum": [
        "kms",
        "vault",
        "env",
        "hsm"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}