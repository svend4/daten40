{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Policy Audit Event Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "actor",
    "action",
    "object_refs",
    "decision_ref",
    "ts",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "object_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_ref": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}