{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Policy Decision Schema v1",
  "type": "object",
  "required": [
    "decision_id",
    "outcome",
    "actions",
    "reason",
    "ts",
    "version"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "require_approval",
        "mask",
        "quarantine"
      ]
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}