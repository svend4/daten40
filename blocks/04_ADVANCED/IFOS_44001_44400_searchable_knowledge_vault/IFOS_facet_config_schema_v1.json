{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS FacetConfig Schema v1",
  "type": "object",
  "required": [
    "facet_id",
    "fields",
    "ranges",
    "sorts",
    "version"
  ],
  "properties": {
    "facet_id": {
      "type": "string"
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "ranges": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "sorts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}