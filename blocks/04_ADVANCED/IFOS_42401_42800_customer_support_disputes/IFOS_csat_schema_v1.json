{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CSAT Schema v1",
  "type": "object",
  "required": [
    "csat_id",
    "ticket_id",
    "score",
    "ts",
    "version"
  ],
  "properties": {
    "csat_id": {
      "type": "string"
    },
    "ticket_id": {
      "type": "string"
    },
    "score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "reasons": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "comment": {
      "type": [
        "string",
        "null"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}