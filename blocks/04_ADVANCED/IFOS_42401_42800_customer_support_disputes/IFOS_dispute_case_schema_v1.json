{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DisputeCase Schema v1",
  "type": "object",
  "required": [
    "case_id",
    "type",
    "parties",
    "status",
    "opened_at",
    "version"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "refund_dispute",
        "chargeback",
        "vendor_dispute",
        "other"
      ]
    },
    "parties": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "awaiting_info",
        "in_review",
        "resolved",
        "closed"
      ]
    },
    "decision": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "evidence_refs": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}