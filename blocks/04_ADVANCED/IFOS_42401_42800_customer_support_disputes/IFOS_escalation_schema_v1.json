{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Escalation Schema v1",
  "type": "object",
  "required": [
    "esc_id",
    "trigger",
    "actions",
    "status",
    "ts",
    "version"
  ],
  "properties": {
    "esc_id": {
      "type": "string"
    },
    "trigger": {
      "type": "object",
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "armed",
        "fired",
        "resolved"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}