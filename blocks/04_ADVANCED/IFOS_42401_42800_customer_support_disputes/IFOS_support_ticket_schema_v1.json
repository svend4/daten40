{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SupportTicket Schema v1",
  "type": "object",
  "required": [
    "ticket_id",
    "tenant_id",
    "category",
    "severity",
    "status",
    "subject",
    "created_at",
    "version"
  ],
  "properties": {
    "ticket_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "user_ref": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "category": {
      "type": "string",
      "enum": [
        "billing",
        "install",
        "run",
        "bug",
        "security",
        "marketplace",
        "other"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "pending_customer",
        "pending_internal",
        "solved",
        "closed"
      ]
    },
    "subject": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "refs": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "tags": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}