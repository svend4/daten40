{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Badge Schema v1",
  "type": "object",
  "required": [
    "badge_id",
    "name",
    "criteria",
    "scope",
    "version"
  ],
  "properties": {
    "badge_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}