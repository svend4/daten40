{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Reputation Schema v1",
  "type": "object",
  "required": [
    "rep_id",
    "subject_type",
    "subject_id",
    "score",
    "level",
    "signals",
    "version"
  ],
  "properties": {
    "rep_id": {
      "type": "string"
    },
    "subject_type": {
      "type": "string",
      "enum": [
        "maintainer",
        "reviewer",
        "user"
      ]
    },
    "subject_id": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "level": {
      "type": "string",
      "enum": [
        "contributor",
        "reviewer",
        "trusted_reviewer",
        "auditor"
      ]
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}