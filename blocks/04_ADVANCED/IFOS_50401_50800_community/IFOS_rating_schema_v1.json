{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Rating Schema v1",
  "type": "object",
  "required": [
    "rating_id",
    "entity_type",
    "entity_id",
    "score",
    "explain",
    "components",
    "version"
  ],
  "properties": {
    "rating_id": {
      "type": "string"
    },
    "entity_type": {
      "type": "string"
    },
    "entity_id": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "explain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}