{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretsPlan Schema v1",
  "type": "object",
  "required": [
    "secrets_id",
    "bundle_id",
    "store",
    "roles",
    "rotation",
    "version"
  ],
  "properties": {
    "secrets_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "store": {
      "type": "string",
      "enum": [
        "env",
        "vault",
        "secret_manager",
        "k8s_secrets"
      ]
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rotation": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}