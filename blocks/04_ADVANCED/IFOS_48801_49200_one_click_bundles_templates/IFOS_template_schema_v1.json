{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Template Schema v1",
  "type": "object",
  "required": [
    "template_id",
    "bundle_id",
    "placeholders",
    "presets",
    "files",
    "version"
  ],
  "properties": {
    "template_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "placeholders": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "presets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}