{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS BundleLockfile Schema v1",
  "type": "object",
  "required": [
    "lock_id",
    "bundle_id",
    "items",
    "hashes",
    "sources",
    "version"
  ],
  "properties": {
    "lock_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}