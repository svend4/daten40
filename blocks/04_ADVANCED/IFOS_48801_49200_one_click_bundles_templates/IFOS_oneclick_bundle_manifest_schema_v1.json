{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS OneClick BundleManifest Schema v1",
  "type": "object",
  "required": [
    "bundle_id",
    "name",
    "goal",
    "items",
    "targets",
    "requirements",
    "secrets",
    "tests",
    "exports",
    "version"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": true
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "exports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}