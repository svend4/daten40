{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CompatibilityReport Schema v1",
  "type": "object",
  "required": [
    "report_id",
    "bundle_id",
    "verified",
    "warnings",
    "failures",
    "version"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "verified": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}