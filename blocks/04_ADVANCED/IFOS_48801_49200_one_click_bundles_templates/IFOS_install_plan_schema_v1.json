{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS InstallPlan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "bundle_id",
    "steps",
    "checkpoints",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}