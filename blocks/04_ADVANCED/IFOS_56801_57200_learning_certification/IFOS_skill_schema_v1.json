{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Skill Schema v1",
  "type": "object",
  "required": [
    "skill_id",
    "name",
    "cluster_ref",
    "difficulty",
    "version"
  ],
  "properties": {
    "skill_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "cluster_ref": {
      "type": "string"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "estimated_hours": {
      "type": "number"
    },
    "version": {
      "type": "string"
    }
  }
}