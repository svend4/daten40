{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Lesson Schema v1",
  "type": "object",
  "required": [
    "lesson_id",
    "title",
    "goal",
    "steps",
    "checks",
    "version"
  ],
  "properties": {
    "lesson_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "common_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}