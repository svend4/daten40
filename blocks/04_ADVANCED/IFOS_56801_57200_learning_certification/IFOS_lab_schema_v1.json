{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Lab Schema v1",
  "type": "object",
  "required": [
    "lab_id",
    "title",
    "dataset",
    "tasks",
    "grading",
    "version"
  ],
  "properties": {
    "lab_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "dataset": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "grading": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}