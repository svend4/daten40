{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Badge Schema v1",
  "type": "object",
  "required": [
    "badge_id",
    "name",
    "level",
    "skills",
    "issuer",
    "version"
  ],
  "properties": {
    "badge_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "L1",
        "L2",
        "L3"
      ]
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issuer": {
      "type": "string"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time"
    },
    "verify_url": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}