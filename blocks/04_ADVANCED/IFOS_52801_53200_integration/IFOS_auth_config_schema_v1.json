{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS AuthConfig Schema v1",
  "type": "object",
  "required": [
    "method",
    "secret_refs",
    "scopes",
    "version"
  ],
  "properties": {
    "method": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth2",
        "basic",
        "jwt_service"
      ]
    },
    "secret_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}