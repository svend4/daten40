{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Connector TestCase Schema v1",
  "type": "object",
  "required": [
    "test_id",
    "connector_id",
    "kind",
    "expected",
    "version"
  ],
  "properties": {
    "test_id": {
      "type": "string"
    },
    "connector_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "auth_smoke",
        "read_sample",
        "write_idempotent",
        "webhook_verify",
        "ratelimit_handling"
      ]
    },
    "expected": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}