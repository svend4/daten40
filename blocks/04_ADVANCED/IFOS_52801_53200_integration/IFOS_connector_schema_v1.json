{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Connector Schema v1",
  "type": "object",
  "required": [
    "connector_id",
    "name",
    "provider",
    "capabilities",
    "auth",
    "resources",
    "limits",
    "version"
  ],
  "properties": {
    "connector_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true
    },
    "auth": {
      "type": "object",
      "additionalProperties": true
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}