{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Request Schema v1",
  "type": "object",
  "required": [
    "method",
    "url",
    "headers",
    "timeout_sec",
    "version"
  ],
  "properties": {
    "method": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "headers": {
      "type": "object",
      "additionalProperties": true
    },
    "body": {
      "type": "object",
      "additionalProperties": true
    },
    "timeout_sec": {
      "type": "number"
    },
    "idempotency_key": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}