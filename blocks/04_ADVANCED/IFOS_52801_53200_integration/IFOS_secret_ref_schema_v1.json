{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SecretRef Schema v1",
  "type": "object",
  "required": [
    "ref",
    "kind",
    "version"
  ],
  "properties": {
    "ref": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "vault",
        "env",
        "os_keystore"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}