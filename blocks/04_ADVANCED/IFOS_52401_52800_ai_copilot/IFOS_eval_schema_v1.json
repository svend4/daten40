{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Eval Schema v1",
  "type": "object",
  "required": [
    "eval_id",
    "metrics",
    "score",
    "notes",
    "version"
  ],
  "properties": {
    "eval_id": {
      "type": "string"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "score": {
      "type": "number"
    },
    "notes": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}