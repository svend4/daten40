{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS AutoDoc Schema v1",
  "type": "object",
  "required": [
    "doc_id",
    "plan_id",
    "files",
    "version"
  ],
  "properties": {
    "doc_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}