{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Lint Finding Schema v1",
  "type": "object",
  "required": [
    "lint_id",
    "severity",
    "message",
    "autofix",
    "version"
  ],
  "properties": {
    "lint_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "error"
      ]
    },
    "message": {
      "type": "string"
    },
    "autofix": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}