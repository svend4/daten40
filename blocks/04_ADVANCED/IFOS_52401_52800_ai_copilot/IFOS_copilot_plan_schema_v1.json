{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CopilotPlan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "intent_id",
    "level",
    "bundles",
    "processes",
    "policies",
    "estimates",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "intent_id": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "simple",
        "medium",
        "enterprise"
      ]
    },
    "bundles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "processes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "estimates": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}