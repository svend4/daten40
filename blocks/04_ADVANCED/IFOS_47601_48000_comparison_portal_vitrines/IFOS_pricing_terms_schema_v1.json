{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PricingTerms Schema v1",
  "type": "object",
  "required": [
    "pricing_id",
    "offer_id",
    "currency",
    "components",
    "version"
  ],
  "properties": {
    "pricing_id": {
      "type": "string"
    },
    "offer_id": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}