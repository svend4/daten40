{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Comparison ProductCard Schema v1",
  "type": "object",
  "required": [
    "card_id",
    "vertical",
    "name",
    "provider",
    "summary",
    "features",
    "limits",
    "citations",
    "version"
  ],
  "properties": {
    "card_id": {
      "type": "string"
    },
    "vertical": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "provider": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "limits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}