{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS FetchJob Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "source_id",
    "state",
    "attempt",
    "scheduled_at",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "ok",
        "failed",
        "paused"
      ]
    },
    "attempt": {
      "type": "integer"
    },
    "scheduled_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_error": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}