{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS NormalizedItem Schema v1",
  "type": "object",
  "required": [
    "item_id",
    "canonical_url",
    "title",
    "published_at",
    "language",
    "body_text",
    "entities",
    "tags",
    "provenance",
    "version"
  ],
  "properties": {
    "item_id": {
      "type": "string"
    },
    "canonical_url": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "language": {
      "type": "string"
    },
    "body_text": {
      "type": "string"
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}