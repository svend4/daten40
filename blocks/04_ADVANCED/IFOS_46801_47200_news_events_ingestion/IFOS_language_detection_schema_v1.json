{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS LanguageDetection Schema v1",
  "type": "object",
  "required": [
    "det_id",
    "item_id",
    "language",
    "confidence",
    "version"
  ],
  "properties": {
    "det_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "version": {
      "type": "string"
    }
  }
}