    "extract_id",
    "item_id",
    "entities",
    "quotes",
    "claims",
    "numbers",
    "version"
  ],
  "properties": {
    "extract_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "numbers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}