{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Enrichment Schema v1",
  "type": "object",
  "required": [
    "enrich_id",
    "item_id",
    "operations",
    "version"
  ],
  "properties": {
    "enrich_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}