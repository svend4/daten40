{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS TimelineEvent Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "cluster_id",
    "kind",
    "start",
    "end",
    "entities",
    "citations",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "cluster_id": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "start": {
      "type": "string",
      "format": "date-time"
    },
    "end": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}