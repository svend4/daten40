{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS QuoteSnippet Schema v1",
  "type": "object",
  "required": [
    "quote_id",
    "item_id",
    "text",
    "offsets",
    "url",
    "version"
  ],
  "properties": {
    "quote_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "offsets": {
      "type": "object",
      "additionalProperties": true
    },
    "url": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}