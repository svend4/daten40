{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DAG Schema v1",
  "type": "object",
  "required": [
    "dag_id",
    "tasks",
    "edges",
    "version"
  ],
  "properties": {
    "dag_id": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "condition": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "version": {
      "type": "string"
    }
  }
}