{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Queue Schema v1",
  "type": "object",
  "required": [
    "queue_id",
    "type",
    "limits",
    "version"
  ],
  "properties": {
    "queue_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "fifo",
        "priority",
        "delayed"
      ]
    },
    "limits": {
      "type": "object",
      "additionalProperties": true
    },
    "tenant_scope": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "resource_classes": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "dlq": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}