{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DocBundle Schema v1",
  "type": "object",
  "required": [
    "doc_id",
    "connector_id",
    "files",
    "generated_at",
    "version"
  ],
  "properties": {
    "doc_id": {
      "type": "string"
    },
    "connector_id": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}