{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ArtifactSigning Schema v1",
  "type": "object",
  "required": [
    "signing_id",
    "method",
    "digest",
    "issuer",
    "ts",
    "version"
  ],
  "properties": {
    "signing_id": {
      "type": "string"
    },
    "method": {
      "type": "string",
      "enum": [
        "sigstore",
        "gpg",
        "x509"
      ]
    },
    "digest": {
      "type": "string"
    },
    "issuer": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}