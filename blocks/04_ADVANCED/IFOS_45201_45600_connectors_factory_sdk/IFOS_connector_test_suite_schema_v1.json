{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ConnectorTestSuite Schema v1",
  "type": "object",
  "required": [
    "suite_id",
    "connector_id",
    "tests",
    "coverage",
    "version"
  ],
  "properties": {
    "suite_id": {
      "type": "string"
    },
    "connector_id": {
      "type": "string"
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "coverage": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}