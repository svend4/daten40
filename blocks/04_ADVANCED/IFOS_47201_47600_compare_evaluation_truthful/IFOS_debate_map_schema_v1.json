{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DebateMap Schema v1",
  "type": "object",
  "required": [
    "map_id",
    "topic",
    "positions",
    "open_questions",
    "version"
  ],
  "properties": {
    "map_id": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}