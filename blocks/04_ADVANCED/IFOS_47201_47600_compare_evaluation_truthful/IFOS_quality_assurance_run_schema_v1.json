{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS QualityAssuranceRun Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "scope",
    "checks",
    "result",
    "ts",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}