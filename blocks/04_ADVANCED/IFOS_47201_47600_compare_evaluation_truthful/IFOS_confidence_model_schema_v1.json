{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ConfidenceModel Schema v1",
  "type": "object",
  "required": [
    "model_id",
    "rules",
    "outputs",
    "version"
  ],
  "properties": {
    "model_id": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}