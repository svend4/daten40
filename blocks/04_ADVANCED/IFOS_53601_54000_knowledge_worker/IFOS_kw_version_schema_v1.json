{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS KW Version Schema v1",
  "type": "object",
  "required": [
    "version_id",
    "object_id",
    "parent",
    "diff",
    "ts",
    "actor",
    "version"
  ],
  "properties": {
    "version_id": {
      "type": "string"
    },
    "object_id": {
      "type": "string"
    },
    "parent": {
      "type": "string"
    },
    "diff": {
      "type": "object",
      "additionalProperties": true
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}