{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS KW Project Schema v1",
  "type": "object",
  "required": [
    "project_id",
    "workspace_id",
    "title",
    "goal",
    "artifacts",
    "status",
    "version"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "archived"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}