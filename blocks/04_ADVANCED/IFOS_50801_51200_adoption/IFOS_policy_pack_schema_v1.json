{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PolicyPack Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "rules",
    "approvals",
    "retention",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}