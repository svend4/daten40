{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Environment Promotion Schema v1",
  "type": "object",
  "required": [
    "promotion_id",
    "from_env",
    "to_env",
    "artifact_versions",
    "created_at",
    "version"
  ],
  "properties": {
    "promotion_id": {
      "type": "string"
    },
    "from_env": {
      "type": "string",
      "enum": [
        "dev",
        "staging",
        "prod"
      ]
    },
    "to_env": {
      "type": "string",
      "enum": [
        "dev",
        "staging",
        "prod"
      ]
    },
    "artifact_versions": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}