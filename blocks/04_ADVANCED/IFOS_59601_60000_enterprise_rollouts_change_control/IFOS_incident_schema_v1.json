{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Incident Schema v1",
  "type": "object",
  "required": [
    "incident_id",
    "severity",
    "summary",
    "timeline",
    "actions",
    "version"
  ],
  "properties": {
    "incident_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "SEV1",
        "SEV2",
        "SEV3"
      ]
    },
    "summary": {
      "type": "string"
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "postmortem_ref": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}