{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Approval Gate Schema v1",
  "type": "object",
  "required": [
    "gate_id",
    "checks",
    "owners",
    "version"
  ],
  "properties": {
    "gate_id": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}