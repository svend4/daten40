{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS CurrencyFX Schema v1",
  "type": "object",
  "required": [
    "fx_id",
    "base",
    "rates",
    "ts",
    "source",
    "version"
  ],
  "properties": {
    "fx_id": {
      "type": "string"
    },
    "base": {
      "type": "string"
    },
    "rates": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}