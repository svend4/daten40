{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS LegalZone Schema v1",
  "type": "object",
  "required": [
    "zone_id",
    "regions",
    "requirements",
    "version"
  ],
  "properties": {
    "zone_id": {
      "type": "string"
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data_residency": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}