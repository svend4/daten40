{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS TranslationBundle Schema v1",
  "type": "object",
  "required": [
    "bundle_id",
    "locale_id",
    "strings",
    "source",
    "version"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "locale_id": {
      "type": "string"
    },
    "strings": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "source": {
      "type": "string",
      "enum": [
        "human",
        "machine",
        "mixed"
      ]
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}