{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS LocaleProfile Schema v1",
  "type": "object",
  "required": [
    "locale_id",
    "language",
    "region",
    "timezone",
    "currency",
    "direction",
    "units",
    "version"
  ],
  "properties": {
    "locale_id": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "timezone": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": [
        "LTR",
        "RTL"
      ]
    },
    "units": {
      "type": "string",
      "enum": [
        "metric",
        "imperial"
      ]
    },
    "date_format": {
      "type": [
        "string",
        "null"
      ]
    },
    "number_format": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}