{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ContentPolicyZone Schema v1",
  "type": "object",
  "required": [
    "zone_id",
    "regions",
    "rules",
    "version"
  ],
  "properties": {
    "zone_id": {
      "type": "string"
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}