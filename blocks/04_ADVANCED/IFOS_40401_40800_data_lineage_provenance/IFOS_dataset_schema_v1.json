{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Dataset Schema v1",
  "type": "object",
  "required": [
    "dataset_id",
    "tenant_id",
    "name",
    "location",
    "format",
    "classification",
    "content_hash",
    "version"
  ],
  "properties": {
    "dataset_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "format": {
      "type": "string"
    },
    "schema_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "PUBLIC",
        "INTERNAL",
        "CONFIDENTIAL",
        "RESTRICTED",
        "PII"
      ]
    },
    "content_hash": {
      "type": "string"
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}