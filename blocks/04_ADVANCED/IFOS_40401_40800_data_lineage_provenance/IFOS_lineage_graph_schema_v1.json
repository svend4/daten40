{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS LineageGraph Schema v1",
  "type": "object",
  "required": [
    "graph_id",
    "nodes",
    "edges",
    "version"
  ],
  "properties": {
    "graph_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}