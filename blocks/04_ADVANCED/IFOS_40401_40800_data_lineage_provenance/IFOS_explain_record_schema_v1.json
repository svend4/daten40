{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ExplainRecord Schema v1",
  "type": "object",
  "required": [
    "explain_id",
    "subject",
    "context",
    "reasons",
    "sources",
    "ts",
    "version"
  ],
  "properties": {
    "explain_id": {
      "type": "string"
    },
    "subject": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}