{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Transformation Schema v1",
  "type": "object",
  "required": [
    "transform_id",
    "actor",
    "asset",
    "inputs",
    "outputs",
    "env",
    "ts",
    "version"
  ],
  "properties": {
    "transform_id": {
      "type": "string"
    },
    "actor": {
      "type": "object",
      "additionalProperties": true
    },
    "asset": {
      "type": "object",
      "additionalProperties": true
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "parameters": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "env": {
      "type": "object",
      "additionalProperties": true
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "metering_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "execution_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}