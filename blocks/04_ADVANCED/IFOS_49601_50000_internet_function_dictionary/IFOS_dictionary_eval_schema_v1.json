{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS DictionaryEval Schema v1",
  "type": "object",
  "required": [
    "eval_id",
    "coverage",
    "accuracy",
    "composition_success",
    "notes",
    "version"
  ],
  "properties": {
    "eval_id": {
      "type": "string"
    },
    "coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "accuracy": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "composition_success": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}