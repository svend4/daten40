{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS FunctionGrammar Schema v1",
  "type": "object",
  "required": [
    "grammar_id",
    "patterns",
    "slots",
    "version"
  ],
  "properties": {
    "grammar_id": {
      "type": "string"
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}