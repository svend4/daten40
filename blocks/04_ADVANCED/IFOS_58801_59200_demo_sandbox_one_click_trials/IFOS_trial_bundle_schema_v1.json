{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Trial Bundle Schema v1",
  "type": "object",
  "required": [
    "trial_id",
    "bundle_ref",
    "sandbox_profile",
    "fixtures",
    "guardrails",
    "version"
  ],
  "properties": {
    "trial_id": {
      "type": "string"
    },
    "bundle_ref": {
      "type": "string"
    },
    "sandbox_profile": {
      "type": "string"
    },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "guardrails": {
      "type": "string"
    },
    "compare_mode": {
      "type": "boolean"
    },
    "version": {
      "type": "string"
    }
  }
}