{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Record-Replay Schema v1",
  "type": "object",
  "required": [
    "session_id",
    "records",
    "redaction",
    "version"
  ],
  "properties": {
    "session_id": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "redaction": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}