{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Adapter Spec Schema v1",
  "type": "object",
  "required": [
    "adapter_id",
    "from_contract",
    "to_contract",
    "mappings",
    "version"
  ],
  "properties": {
    "adapter_id": {
      "type": "string"
    },
    "from_contract": {
      "type": "string"
    },
    "to_contract": {
      "type": "string"
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "transforms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}