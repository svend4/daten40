{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PartnerApiKey Schema v1",
  "type": "object",
  "required": [
    "key_id",
    "partner_id",
    "scopes",
    "status",
    "created_at",
    "version"
  ],
  "properties": {
    "key_id": {
      "type": "string"
    },
    "partner_id": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "revoked",
        "expired"
      ]
    },
    "rotation_days": {
      "type": [
        "integer",
        "null"
      ]
    },
    "usage_limits": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}