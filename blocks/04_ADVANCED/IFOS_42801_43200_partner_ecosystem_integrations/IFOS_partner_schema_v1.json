{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Partner Schema v1",
  "type": "object",
  "required": [
    "partner_id",
    "name",
    "type",
    "status",
    "regions",
    "created_at",
    "version"
  ],
  "properties": {
    "partner_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "vendor",
        "platform",
        "affiliate",
        "agency",
        "developer"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "active",
        "suspended",
        "revoked"
      ]
    },
    "contacts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "legal_zones": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}