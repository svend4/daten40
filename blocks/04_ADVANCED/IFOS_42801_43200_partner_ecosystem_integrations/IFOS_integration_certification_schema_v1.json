{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS IntegrationCertification Schema v1",
  "type": "object",
  "required": [
    "cert_id",
    "integration_id",
    "level",
    "checks",
    "status",
    "reviewed_at",
    "version"
  ],
  "properties": {
    "cert_id": {
      "type": "string"
    },
    "integration_id": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "bronze",
        "silver",
        "gold"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "expired",
        "in_review"
      ]
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}