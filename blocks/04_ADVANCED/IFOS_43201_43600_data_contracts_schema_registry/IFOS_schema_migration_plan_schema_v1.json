{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SchemaMigrationPlan Schema v1",
  "type": "object",
  "required": [
    "plan_id",
    "schema_id",
    "from_version",
    "to_version",
    "strategy",
    "mappings",
    "deadline",
    "version"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    },
    "from_version": {
      "type": "string"
    },
    "to_version": {
      "type": "string"
    },
    "strategy": {
      "type": "string",
      "enum": [
        "dual_write",
        "shadow_read",
        "big_bang",
        "adapter_layer"
      ]
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "deadline": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}