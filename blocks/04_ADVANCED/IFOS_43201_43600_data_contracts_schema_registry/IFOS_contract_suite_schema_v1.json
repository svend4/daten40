{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ContractSuite Schema v1",
  "type": "object",
  "required": [
    "suite_id",
    "name",
    "tests",
    "ts",
    "version"
  ],
  "properties": {
    "suite_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}