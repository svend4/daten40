{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SchemaRegistry Schema v1",
  "type": "object",
  "required": [
    "registry_id",
    "records",
    "policies",
    "updated_at",
    "version"
  ],
  "properties": {
    "registry_id": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": true
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}