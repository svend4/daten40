{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ContractTest Schema v1",
  "type": "object",
  "required": [
    "test_id",
    "schema_id",
    "versions",
    "samples",
    "expect",
    "version"
  ],
  "properties": {
    "test_id": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    },
    "versions": {
      "type": "string"
    },
    "samples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}