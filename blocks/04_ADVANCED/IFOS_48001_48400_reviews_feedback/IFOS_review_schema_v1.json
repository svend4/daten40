{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Review Schema v1",
  "type": "object",
  "required": [
    "review_id",
    "target",
    "author_id",
    "text",
    "structured",
    "context",
    "ts",
    "status",
    "version"
  ],
  "properties": {
    "review_id": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "additionalProperties": true
    },
    "author_id": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "structured": {
      "type": "object",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "published",
        "pending",
        "hidden"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}