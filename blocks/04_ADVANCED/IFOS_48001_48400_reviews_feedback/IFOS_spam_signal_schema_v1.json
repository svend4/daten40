{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SpamSignal Schema v1",
  "type": "object",
  "required": [
    "signal_id",
    "review_id",
    "signals",
    "score",
    "version"
  ],
  "properties": {
    "signal_id": {
      "type": "string"
    },
    "review_id": {
      "type": "string"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "version": {
      "type": "string"
    }
  }
}