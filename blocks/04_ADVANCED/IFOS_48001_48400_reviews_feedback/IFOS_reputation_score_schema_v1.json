{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ReputationScore Schema v1",
  "type": "object",
  "required": [
    "rep_id",
    "subject_type",
    "subject_id",
    "score",
    "explain",
    "version"
  ],
  "properties": {
    "rep_id": {
      "type": "string"
    },
    "subject_type": {
      "type": "string",
      "enum": [
        "reviewer",
        "provider"
      ]
    },
    "subject_id": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "explain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}