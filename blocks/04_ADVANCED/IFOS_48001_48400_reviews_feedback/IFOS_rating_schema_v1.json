{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Rating Schema v1",
  "type": "object",
  "required": [
    "rating_id",
    "review_id",
    "overall",
    "subscores",
    "weight",
    "version"
  ],
  "properties": {
    "rating_id": {
      "type": "string"
    },
    "review_id": {
      "type": "string"
    },
    "overall": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "subscores": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "weight": {
      "type": "number",
      "minimum": 0
    },
    "version": {
      "type": "string"
    }
  }
}