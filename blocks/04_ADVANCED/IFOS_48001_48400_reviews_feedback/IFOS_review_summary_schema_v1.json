{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ReviewSummary Schema v1",
  "type": "object",
  "required": [
    "summary_id",
    "target_id",
    "topics",
    "trends",
    "fit",
    "version"
  ],
  "properties": {
    "summary_id": {
      "type": "string"
    },
    "target_id": {
      "type": "string"
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "trends": {
      "type": "object",
      "additionalProperties": true
    },
    "fit": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}