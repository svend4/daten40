{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Process Schema v1",
  "type": "object",
  "required": [
    "process_id",
    "name",
    "trigger",
    "steps",
    "version"
  ],
  "properties": {
    "process_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "trigger": {
      "type": "object",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}