{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Form Schema v1",
  "type": "object",
  "required": [
    "form_id",
    "fields",
    "version"
  ],
  "properties": {
    "form_id": {
      "type": "string"
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}