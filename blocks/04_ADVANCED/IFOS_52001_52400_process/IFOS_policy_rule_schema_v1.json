{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PolicyRule Schema v1",
  "type": "object",
  "required": [
    "policy_id",
    "when",
    "then",
    "severity",
    "version"
  ],
  "properties": {
    "policy_id": {
      "type": "string"
    },
    "when": {
      "type": "object",
      "additionalProperties": true
    },
    "then": {
      "type": "object",
      "additionalProperties": true
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "block"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}