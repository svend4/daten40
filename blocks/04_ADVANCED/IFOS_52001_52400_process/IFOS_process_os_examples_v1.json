{
  "process_dsl": "on event: email_received\nstep classify\nbranch risk==high -> approval\nstep create_ticket\nend",
  "process": {
    "process_id": "proc.p.9cnukmxqaffn",
    "name": "Email → Ticket",
    "trigger": {
      "type": "event",
      "spec": {
        "name": "email_received"
      }
    },
    "steps": [
      {
        "step_id": "s1",
        "type": "auto",
        "action": {
          "bundle": "bun.classify"
        },
        "on_success": "s2",
        "on_error": "e1",
        "version": "1.0.0"
      },
      {
        "step_id": "s2",
        "type": "branch",
        "action": {
          "expr": "risk==high",
          "true": "s3",
          "false": "s4"
        },
        "on_success": "s4",
        "on_error": "e1",
        "version": "1.0.0"
      },
      {
        "step_id": "s3",
        "type": "approval",
        "action": {
          "role": "manager",
          "deadline": "48h"
        },
        "on_success": "s4",
        "on_error": "e1",
        "version": "1.0.0"
      },
      {
        "step_id": "s4",
        "type": "auto",
        "action": {
          "bundle": "bun.create_ticket"
        },
        "on_success": "done",
        "on_error": "e1",
        "version": "1.0.0"
      }
    ],
    "version": "1.0.0"
  },
  "policy": {
    "policy_id": "pol.r.z3epryfhto5z",
    "when": {
      "field": "amount",
      "op": ">",
      "value": 500
    },
    "then": {
      "require_approvals": 2
    },
    "severity": "block",
    "version": "1.0.0"
  },
  "approval": {
    "approval_id": "app.a.l0xajq4n2t9u",
    "who": {
      "role": "manager"
    },
    "deadline": "2026-01-06T12:00:00Z",
    "status": "pending",
    "version": "1.0.0"
  }
}