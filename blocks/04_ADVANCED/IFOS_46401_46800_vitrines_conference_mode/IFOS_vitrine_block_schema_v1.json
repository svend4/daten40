{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS VitrineBlock Schema v1",
  "type": "object",
  "required": [
    "block_id",
    "type",
    "config",
    "version"
  ],
  "properties": {
    "block_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "feed",
        "compare",
        "table",
        "kpi",
        "timeline",
        "actions"
      ]
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}