{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ItemUpdateEvent Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "item_id",
    "kind",
    "ts",
    "payload",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "new",
        "update",
        "correction",
        "retract"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}