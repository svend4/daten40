{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS SourceCredibility Schema v1",
  "type": "object",
  "required": [
    "source_id",
    "domain",
    "score",
    "signals",
    "version"
  ],
  "properties": {
    "source_id": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "signals": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}