{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS EnrichmentJob Schema v1",
  "type": "object",
  "required": [
    "job_id",
    "item_id",
    "steps",
    "status",
    "ts",
    "version"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "done",
        "error"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}