{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS LanguageDetectResult Schema v1",
  "type": "object",
  "required": [
    "item_id",
    "locale",
    "confidence",
    "ts",
    "version"
  ],
  "properties": {
    "item_id": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}