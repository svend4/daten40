{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vault Provenance Record Schema v1",
  "type": "object",
  "required": [
    "prov_id",
    "artifact_id",
    "source",
    "actor",
    "ts",
    "transformations",
    "evidence",
    "version"
  ],
  "properties": {
    "prov_id": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "upload",
        "import",
        "runtime",
        "external"
      ]
    },
    "actor": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "transformations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}