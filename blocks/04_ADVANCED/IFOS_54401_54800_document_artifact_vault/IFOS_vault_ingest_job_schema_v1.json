{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vault Ingest Job Schema v1",
  "type": "object",
  "required": [
    "ingest_id",
    "source",
    "status",
    "results",
    "version"
  ],
  "properties": {
    "ingest_id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "done",
        "failed"
      ]
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}