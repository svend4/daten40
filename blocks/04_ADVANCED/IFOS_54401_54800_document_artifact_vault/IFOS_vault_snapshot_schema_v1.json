{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vault Snapshot Schema v1",
  "type": "object",
  "required": [
    "snapshot_id",
    "ts",
    "objects",
    "signature_ref",
    "version"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "signature_ref": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}