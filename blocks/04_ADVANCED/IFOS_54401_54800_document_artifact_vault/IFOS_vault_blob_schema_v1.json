    "content_hash",
    "size",
    "mime_type",
    "version"
  ],
  "properties": {
    "content_hash": {
      "type": "string"
    },
    "size": {
      "type": "integer"
    },
    "mime_type": {
      "type": "string"
    },
    "encryption_ref": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}