{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vault Share Link Schema v1",
  "type": "object",
  "required": [
    "share_id",
    "scope",
    "permissions",
    "expiry",
    "audit_enabled",
    "version"
  ],
  "properties": {
    "share_id": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expiry": {
      "type": "string",
      "format": "date-time"
    },
    "audit_enabled": {
      "type": "boolean"
    },
    "version": {
      "type": "string"
    }
  }
}