{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Bundle Schema v1",
  "type": "object",
  "required": [
    "bundle_id",
    "title",
    "items",
    "dependencies",
    "recipes",
    "artifacts",
    "version"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}