{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS PublishJob Schema v1",
  "type": "object",
  "required": [
    "publish_id",
    "targets",
    "inputs",
    "status",
    "ts",
    "version"
  ],
  "properties": {
    "publish_id": {
      "type": "string"
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "done",
        "error"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "outputs": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}