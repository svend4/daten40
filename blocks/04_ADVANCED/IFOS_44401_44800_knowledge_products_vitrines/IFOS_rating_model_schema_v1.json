{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RatingModel Schema v1",
  "type": "object",
  "required": [
    "model_id",
    "signals",
    "anti_fraud",
    "version"
  ],
  "properties": {
    "model_id": {
      "type": "string"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "anti_fraud": {
      "type": "object",
      "additionalProperties": true
    },
    "weights": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}