{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Vitrine Schema v1",
  "type": "object",
  "required": [
    "vitrine_id",
    "title",
    "rules",
    "cards",
    "layout",
    "actions",
    "version"
  ],
  "properties": {
    "vitrine_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "rules": {
      "type": "object",
      "additionalProperties": true
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}