{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS InstallRecipe Schema v1",
  "type": "object",
  "required": [
    "recipe_id",
    "title",
    "steps",
    "checks",
    "rollback",
    "version"
  ],
  "properties": {
    "recipe_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "checks": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "rollback": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}