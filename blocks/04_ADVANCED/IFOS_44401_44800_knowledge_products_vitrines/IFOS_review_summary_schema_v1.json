{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ReviewSummary Schema v1",
  "type": "object",
  "required": [
    "summary_id",
    "item_id",
    "pros",
    "cons",
    "facts",
    "confidence",
    "version"
  ],
  "properties": {
    "summary_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "pros": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "version": {
      "type": "string"
    }
  }
}