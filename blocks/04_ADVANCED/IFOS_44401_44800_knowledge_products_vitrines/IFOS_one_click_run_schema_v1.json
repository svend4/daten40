{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS OneClickRun Schema v1",
  "type": "object",
  "required": [
    "run_id",
    "bundle_id",
    "target",
    "params",
    "sandbox",
    "status",
    "ts",
    "version"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "target": {
      "type": "string",
      "enum": [
        "cloud",
        "local",
        "edge"
      ]
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    },
    "sandbox": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "done",
        "error"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "logs_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}