{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Comparison Schema v1",
  "type": "object",
  "required": [
    "comparison_id",
    "title",
    "items",
    "criteria",
    "matrix",
    "recommendations",
    "version"
  ],
  "properties": {
    "comparison_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "version": {
      "type": "string"
    }
  }
}