{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RegistryTagging Schema v1",
  "type": "object",
  "required": [
    "tag_id",
    "item_id",
    "tags",
    "clusters",
    "version"
  ],
  "properties": {
    "tag_id": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}