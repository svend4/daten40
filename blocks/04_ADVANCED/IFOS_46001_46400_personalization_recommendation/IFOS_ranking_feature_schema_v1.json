{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS RankingFeature Schema v1",
  "type": "object",
  "required": [
    "feature_id",
    "name",
    "type",
    "description",
    "version"
  ],
  "properties": {
    "feature_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "numeric",
        "categorical",
        "boolean",
        "text"
      ]
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}