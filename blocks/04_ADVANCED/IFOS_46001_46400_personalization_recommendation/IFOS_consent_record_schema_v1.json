{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS ConsentRecord Schema v1",
  "type": "object",
  "required": [
    "consent_id",
    "user_id",
    "scopes",
    "granted",
    "ts",
    "version"
  ],
  "properties": {
    "consent_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string"
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "granted": {
      "type": "boolean"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}