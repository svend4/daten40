{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Moderation Case Schema v1",
  "type": "object",
  "required": [
    "case_id",
    "target_ref",
    "reason_code",
    "status",
    "created_at",
    "version"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "target_ref": {
      "type": "string"
    },
    "reason_code": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "quarantined",
        "resolved",
        "appealed"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}