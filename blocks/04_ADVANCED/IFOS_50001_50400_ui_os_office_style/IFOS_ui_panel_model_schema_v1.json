{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UIPanelModel Schema v1",
  "type": "object",
  "required": [
    "panel_id",
    "type",
    "data",
    "version"
  ],
  "properties": {
    "panel_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "trust",
        "quality",
        "security",
        "freshness",
        "cost",
        "compatibility"
      ]
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}