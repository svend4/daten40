{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UICommandModel Schema v1",
  "type": "object",
  "required": [
    "cmd_id",
    "intent",
    "terms",
    "params",
    "target",
    "version"
  ],
  "properties": {
    "cmd_id": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    },
    "target": {
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  }
}