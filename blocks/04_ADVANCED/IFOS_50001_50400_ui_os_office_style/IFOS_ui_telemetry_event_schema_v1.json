{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UITelemetryEvent Schema v1",
  "type": "object",
  "required": [
    "event_id",
    "name",
    "ts",
    "props",
    "version"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "props": {
      "type": "object",
      "additionalProperties": true
    },
    "version": {
      "type": "string"
    }
  }
}