{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UIJournalModel Schema v1",
  "type": "object",
  "required": [
    "journal_id",
    "entries",
    "export_formats",
    "version"
  ],
  "properties": {
    "journal_id": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "export_formats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}