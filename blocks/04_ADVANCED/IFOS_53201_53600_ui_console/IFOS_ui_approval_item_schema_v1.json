{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UI Approval Item Schema v1",
  "type": "object",
  "required": [
    "approval_id",
    "status",
    "deadline",
    "role",
    "context",
    "diff",
    "actions",
    "version"
  ],
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "deadline": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "diff": {
      "type": "object",
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}