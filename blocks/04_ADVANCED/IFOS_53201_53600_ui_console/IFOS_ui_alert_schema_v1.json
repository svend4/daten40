{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS UI Alert Schema v1",
  "type": "object",
  "required": [
    "alert_id",
    "severity",
    "message",
    "impacted",
    "suggested_actions",
    "version"
  ],
  "properties": {
    "alert_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "error",
        "critical"
      ]
    },
    "message": {
      "type": "string"
    },
    "impacted": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suggested_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string"
    }
  }
}