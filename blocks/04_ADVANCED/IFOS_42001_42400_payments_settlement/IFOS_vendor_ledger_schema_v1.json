{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS VendorLedger Schema v1",
  "type": "object",
  "required": [
    "vendor_id",
    "entries",
    "balance",
    "available",
    "currency",
    "version"
  ],
  "properties": {
    "vendor_id": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "balance": {
      "type": "number"
    },
    "available": {
      "type": "number"
    },
    "reserves": {
      "type": [
        "number",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}