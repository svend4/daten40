{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Quote Schema v1",
  "type": "object",
  "required": [
    "quote_id",
    "tenant_id",
    "items",
    "amounts",
    "status",
    "expires_at",
    "ts",
    "version"
  ],
  "properties": {
    "quote_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "amounts": {
      "type": "object",
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "accepted",
        "expired",
        "cancelled"
      ]
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    }
  }
}