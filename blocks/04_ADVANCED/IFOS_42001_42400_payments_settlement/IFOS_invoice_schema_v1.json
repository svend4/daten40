{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Invoice Schema v1",
  "type": "object",
  "required": [
    "invoice_id",
    "number",
    "seller",
    "buyer",
    "items",
    "totals",
    "status",
    "issued_at",
    "version"
  ],
  "properties": {
    "invoice_id": {
      "type": "string"
    },
    "number": {
      "type": "string"
    },
    "seller": {
      "type": "object",
      "additionalProperties": true
    },
    "buyer": {
      "type": "object",
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": true
    },
    "tax": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "issued",
        "paid",
        "void",
        "overdue"
      ]
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "due_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "pdf_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}