{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IFOS Receipt Schema v1",
  "type": "object",
  "required": [
    "receipt_id",
    "invoice_id",
    "intent_id",
    "paid_at",
    "amount",
    "currency",
    "version"
  ],
  "properties": {
    "receipt_id": {
      "type": "string"
    },
    "invoice_id": {
      "type": "string"
    },
    "intent_id": {
      "type": "string"
    },
    "paid_at": {
      "type": "string",
      "format": "date-time"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "processor_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  }
}